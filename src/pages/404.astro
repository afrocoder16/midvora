---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — Midvora">
<section style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:4rem 1.25rem;background:#F8F6F2;">
  <div style="max-width:32rem;">
    <p style="font:700 0.62rem/1 'Inter Tight',sans-serif;letter-spacing:0.22em;text-transform:uppercase;color:#0054DF;margin-bottom:1.25rem;">404</p>
    <h1 style="font-family:'Oswald',sans-serif;font-weight:700;font-size:clamp(2.5rem,6vw,4rem);line-height:1;color:#0A1628;margin:0 0 1rem;">Page not found.</h1>
    <p style="font:500 1rem/1.65 'Inter Tight',sans-serif;color:#6B7280;margin:0 0 2.5rem;">The page you're looking for doesn't exist. Let's get you back on track.</p>
    <a href="/" style="display:inline-flex;align-items:center;gap:0.5rem;border-radius:999px;background:#F96B2B;padding:0.9rem 2rem;font:700 0.9rem/1 'Inter Tight',sans-serif;color:#fff;text-decoration:none;box-shadow:0 16px 36px rgba(249,107,43,0.28);">
      Back to home
    </a>
  </div>
</section>
</BaseLayout>
