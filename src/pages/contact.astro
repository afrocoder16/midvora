---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Midvora">

<!-- ══════════════════════════════════════
     §1 HERO
══════════════════════════════════════ -->
<section class="ct-hero">
  <div class="ct-hero-inner">
    <p class="ct-eyebrow">Let&rsquo;s build something</p>
    <h1 class="ct-hero-h1">Tell us about your business.<br class="hidden md:block"/> We&rsquo;ll do the rest.</h1>
    <p class="ct-hero-sub">Send us your info and we&rsquo;ll build a live working sample of your website in 24 hours. Free. No commitment. Yours to keep.</p>
    <div class="ct-trust-row">
      {[
        'Delivered in 24 hours',
        'No payment required',
        'Keep it even if you pass',
      ].map(t => (
        <div class="ct-trust-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          <span>{t}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     §2 FORM + CONTACT INFO
══════════════════════════════════════ -->
<section class="ct-form-section" id="contact-form-section">
  <div class="ct-form-grid">

    <!-- LEFT: form -->
    <div class="ct-form-col" id="ct-form-wrap">

      <form id="ct-form" novalidate>

        <!-- Row 1: Business + Name -->
        <div class="ct-row-2">
          <input class="ct-input" type="text"  name="businessName" required placeholder="Main Street Pizza" autocomplete="organization"/>
          <input class="ct-input" type="text"  name="yourName"     required placeholder="Maria Garcia" autocomplete="name"/>
        </div>

        <!-- Row 2: Business type -->
        <div class="ct-select-wrap">
          <select class="ct-input ct-select" name="businessType">
            <option value="" disabled selected>What kind of business?</option>
            {['Restaurant / Cafe','Salon & Spa','Barbershop','Contractor','Gym & Fitness','Retail Store','Event Planner','Photographer','Real Estate','Other'].map(o => (
              <option value={o}>{o}</option>
            ))}
          </select>
          <svg class="ct-select-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </div>

        <!-- Row 3: City + Website -->
        <div class="ct-row-2">
          <input class="ct-input" type="text" name="cityState"       placeholder="Marshall, MN" autocomplete="address-level2"/>
          <input class="ct-input" type="url"  name="currentWebsite"  placeholder="Current website if you have one" autocomplete="url"/>
        </div>

        <!-- Row 4: Email + Phone -->
        <div class="ct-row-2">
          <input class="ct-input" type="email" name="email" required placeholder="you@email.com" autocomplete="email"/>
          <input class="ct-input" type="tel"   name="phone"           placeholder="(507) 555-0123" autocomplete="tel"/>
        </div>

        <!-- Row 5: Message -->
        <textarea class="ct-input ct-textarea" name="message" rows="4" placeholder="A new website, a redesign, online ordering, Google setup, tell us anything."></textarea>

        <!-- Row 6: Submit -->
        <button type="submit" class="ct-submit" id="ct-submit-btn">
          Build my free sample &rarr;
        </button>
        <p class="ct-submit-note">We&rsquo;ll review your info and send you a sample link within 24 hours.</p>
        <p class="ct-error-msg" id="ct-error" style="display:none;">Something went wrong. Please try again or call us at <a href="tel:+15075304837">(507) 530-4837</a>.</p>

      </form>

      <!-- Success state (hidden until submit) -->
      <div class="ct-success" id="ct-success" style="display:none;">
        <div class="ct-success-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <h2 class="ct-success-title">We got it!</h2>
        <p class="ct-success-body">Check your email in the next 24 hours for your free website sample.</p>
        <p class="ct-success-call">Want to talk now? Call <a href="tel:+15075304837">(507) 530-4837</a></p>
      </div>

    </div>

    <!-- RIGHT: contact info (sticky) -->
    <aside class="ct-info-col">
      <div class="ct-info-card">
        <h2 class="ct-info-title">Other ways to reach us</h2>

        <div class="ct-info-items">

          <div class="ct-info-item">
            <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            <div>
              <p class="ct-info-label">Visit us</p>
              <p class="ct-info-val">107 E Main, Marshall, MN 56258</p>
            </div>
          </div>

          <div class="ct-info-item">
            <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <div>
              <p class="ct-info-label">Call or text</p>
              <a href="tel:+15075304837" class="ct-info-link">(507) 530-4837</a>
            </div>
          </div>

          <div class="ct-info-item">
            <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <p class="ct-info-label">Email</p>
              <a href="mailto:info@midvora.com" class="ct-info-link">info@midvora.com</a>
            </div>
          </div>

        </div>

        <div class="ct-info-divider"></div>

        <div class="ct-info-item">
          <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#F96B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <p class="ct-info-label">Response time</p>
            <p class="ct-info-val">We respond within 2 hours. Usually faster.</p>
          </div>
        </div>

        <div class="ct-info-divider"></div>

        <div class="ct-info-item">
          <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <div>
            <p class="ct-info-label">Hours</p>
            <p class="ct-info-val">Monday – Friday: 8am – 6pm CT</p>
            <p class="ct-info-val">Saturday: By appointment</p>
            <p class="ct-info-val ct-val-muted">Sunday: Closed</p>
          </div>
        </div>

        <div class="ct-info-divider"></div>

        <div class="ct-info-item">
          <svg class="ct-info-icon" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <div>
            <p class="ct-info-label">Service area</p>
            <p class="ct-info-val">Minnesota · South Dakota · North Dakota</p>
            <p class="ct-info-val ct-val-muted">Remote clients welcome anywhere.</p>
          </div>
        </div>

      </div>
    </aside>

  </div>
</section>

<!-- ══════════════════════════════════════
     §3 WHAT HAPPENS NEXT
══════════════════════════════════════ -->
<section class="ct-next">
  <div class="ct-next-inner">
    <p class="ct-eyebrow ct-next-ew">What happens next</p>
    <h2 class="ct-next-h2">Three steps. That&rsquo;s it.</h2>

    <div class="ct-steps-wrap">
      <div class="ct-steps-grid">

        <div class="ct-step">
          <p class="ct-step-num">1</p>
          <h3 class="ct-step-title">You submit this form</h3>
          <p class="ct-step-body">Takes 60 seconds.</p>
        </div>

        <div class="ct-step-arrow" aria-hidden="true">&rarr;</div>

        <div class="ct-step">
          <p class="ct-step-num">2</p>
          <h3 class="ct-step-title">We build your sample</h3>
          <p class="ct-step-body">Live site in 24 hours.</p>
        </div>

        <div class="ct-step-arrow" aria-hidden="true">&rarr;</div>

        <div class="ct-step">
          <p class="ct-step-num">3</p>
          <h3 class="ct-step-title">You decide</h3>
          <p class="ct-step-body">Love it or leave it. No pressure.</p>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     §4 FAQ
══════════════════════════════════════ -->
<section class="ct-faq">
  <div class="ct-faq-inner">
    <h2 class="ct-faq-h2">Quick answers</h2>

    <div class="ct-faq-list" id="ct-faq-list">
      {[
        {
          q: 'Is the free sample really free?',
          a: 'Yes. We build it with your real business info and send you the link. If you don\'t want to move forward, you keep the sample and owe us nothing. We do this because we\'re confident you\'ll love the work.',
        },
        {
          q: 'How do you build a website in 24 hours?',
          a: 'We use AI-powered development tools that let us build in hours what used to take weeks. The technology is new, but our standards aren\'t. Every site is custom, secure, and tested before you see it.',
        },
        {
          q: 'What if I already have a website?',
          a: 'Even better. We\'ll build a sample of what your refreshed site could look like. You can compare side by side and decide if the upgrade is worth it.',
        },
      ].map((item) => (
        <div class="ct-faq-item">
          <button class="ct-faq-q" type="button" aria-expanded="false">
            <span>{item.q}</span>
            <svg class="ct-faq-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="ct-faq-body"><p class="ct-faq-a">{item.a}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     §5 BOTTOM CTA
══════════════════════════════════════ -->
<section class="ct-cta">
  <div class="ct-cta-inner">
    <h2 class="ct-cta-h2">Still thinking about it?</h2>
    <p class="ct-cta-sub">No rush. But if you want to see what we can do, it only takes 60 seconds.</p>
    <div class="ct-cta-btns">
      <button class="ct-cta-primary" id="ct-scroll-up">Go back to the form &uarr;</button>
      <a href="tel:+15075304837" class="ct-cta-ghost">Call (507) 530-4837</a>
    </div>
  </div>
</section>

</BaseLayout>

<!-- CDN -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
/* ── FAQ accordion ── */
(function () {
  document.querySelectorAll('.ct-faq-item').forEach(function (item) {
    var btn  = item.querySelector('.ct-faq-q');
    var body = item.querySelector('.ct-faq-body');
    var chev = item.querySelector('.ct-faq-chev');
    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.ct-faq-item').forEach(function (el) {
        el.querySelector('.ct-faq-q').setAttribute('aria-expanded', 'false');
        el.querySelector('.ct-faq-body').style.maxHeight = '0';
        el.querySelector('.ct-faq-chev').style.transform = 'rotate(0deg)';
      });
      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        chev.style.transform = 'rotate(180deg)';
      }
    });
  });
})();

/* ── Form submission ── */
(function () {
  var form    = document.getElementById('ct-form');
  var wrap    = document.getElementById('ct-form-wrap');
  var success = document.getElementById('ct-success');
  var errMsg  = document.getElementById('ct-error');
  var btn     = document.getElementById('ct-submit-btn');
  if (!form) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var data = {};
    new FormData(form).forEach(function (v, k) { data[k] = v; });
    btn.disabled = true;
    btn.textContent = 'Sending...';
    errMsg.style.display = 'none';

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        access_key: 'e7f6edce-9410-45b7-a058-a03f661f953b',
        subject: 'New Free Sample Request — Midvora',
        from_name: data.businessName || data.yourName,
        businessName: data.businessName,
        yourName: data.yourName,
        businessType: data.businessType,
        cityState: data.cityState,
        currentWebsite: data.currentWebsite,
        email: data.email,
        phone: data.phone,
        message: data.message,
      }),
    })
      .then(function (res) { return res.json(); })
      .then(function (json) {
        if (!json.success) throw new Error('fail');
        /* success */
        if (typeof gsap !== 'undefined') {
          gsap.to(form, {
            opacity: 0, y: -16, duration: 0.35, ease: 'power2.in',
            onComplete: function () {
              form.style.display = 'none';
              success.style.display = 'flex';
              gsap.fromTo(success, { opacity:0, scale:0.93 }, { opacity:1, scale:1, duration:0.5, ease:'back.out(1.4)' });
            }
          });
        } else {
          form.style.display = 'none';
          success.style.display = 'flex';
        }
      })
      .catch(function () {
        errMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Build my free sample →';
      });
  });
})();

/* ── Scroll up button ── */
(function () {
  var upBtn = document.getElementById('ct-scroll-up');
  if (upBtn) {
    upBtn.addEventListener('click', function () {
      var target = document.getElementById('contact-form-section');
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  }
})();

/* ── GSAP ── */
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);
  var ease = 'power2.out';

  /* hero */
  gsap.fromTo('.ct-hero-h1',   { opacity:0, y:36 }, { opacity:1, y:0, duration:0.8, ease:'power3.out', delay:0.1 });
  gsap.fromTo('.ct-hero-sub',  { opacity:0, y:20 }, { opacity:1, y:0, duration:0.65, ease:ease, delay:0.3 });
  gsap.fromTo('.ct-trust-item',{ opacity:0, y:14 }, { opacity:1, y:0, duration:0.45, ease:ease, stagger:0.1, delay:0.45 });

  /* form + info card */
  gsap.fromTo('.ct-form-col',
    { opacity:0, x:-28 },
    { opacity:1, x:0, duration:0.75, ease:ease,
      scrollTrigger:{ trigger:'.ct-form-grid', start:'top 80%', once:true } });
  gsap.fromTo('.ct-info-col',
    { opacity:0, x:28 },
    { opacity:1, x:0, duration:0.75, ease:ease,
      scrollTrigger:{ trigger:'.ct-form-grid', start:'top 80%', once:true } });

  /* steps */
  gsap.fromTo('.ct-next-ew,.ct-next-h2',
    { opacity:0, y:20 },
    { opacity:1, y:0, duration:0.6, ease:ease, stagger:0.12,
      scrollTrigger:{ trigger:'.ct-next', start:'top 80%', once:true } });
  gsap.fromTo('.ct-step',
    { opacity:0, y:32 },
    { opacity:1, y:0, duration:0.55, ease:ease, stagger:0.15,
      scrollTrigger:{ trigger:'.ct-steps-grid', start:'top 82%', once:true } });

  /* faq */
  gsap.fromTo('.ct-faq-item',
    { opacity:0, y:18 },
    { opacity:1, y:0, duration:0.5, ease:ease, stagger:0.1,
      scrollTrigger:{ trigger:'.ct-faq-list', start:'top 82%', once:true } });

  /* cta */
  gsap.fromTo('.ct-cta-inner > *',
    { opacity:0, y:20 },
    { opacity:1, y:0, duration:0.6, ease:ease, stagger:0.12,
      scrollTrigger:{ trigger:'.ct-cta', start:'top 82%', once:true } });
})();
</script>

<style is:inline>
/* ─── SHARED ─── */
.ct-eyebrow {
  font:700 0.6rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.22em;text-transform:uppercase;
  color:#0054DF;display:block;margin-bottom:1.25rem;
}

/* ─── §1 HERO ─── */
.ct-hero {
  background:#F8F6F2;
  padding:clamp(7rem,12vw,9rem) 1.25rem clamp(3rem,6vw,5rem);
  text-align:center;
}
.ct-hero-inner { max-width:44rem;margin:0 auto; }
.ct-hero-h1 {
  font-family:'Oswald',sans-serif;font-weight:700;
  font-size:clamp(2.4rem,6.5vw,4rem);line-height:1.0;
  letter-spacing:-0.015em;color:#0A1628;margin:0 0 1.25rem;
}
.ct-hero-sub {
  font:500 1rem/1.65 'Inter Tight',sans-serif;
  color:#9CA3AF;margin:0 0 2rem;max-width:34rem;margin-left:auto;margin-right:auto;
}
.ct-trust-row {
  display:flex;flex-wrap:wrap;gap:1rem 1.75rem;justify-content:center;align-items:center;
}
.ct-trust-item {
  display:flex;align-items:center;gap:0.45rem;
  font:500 0.82rem/1 'Inter Tight',sans-serif;color:#6B7280;
}

/* ─── §2 FORM SECTION ─── */
.ct-form-section {
  background:#fff;
  padding:clamp(4rem,8vw,6rem) 1.25rem;
}
.ct-form-grid {
  display:grid;
  grid-template-columns:3fr 2fr;
  gap:3.5rem;
  max-width:56rem;margin:0 auto;
  align-items:start;
}
@media (max-width:767px) {
  .ct-form-grid { grid-template-columns:1fr;gap:2.5rem; }
}

/* Form fields */
.ct-row-2 {
  display:grid;grid-template-columns:1fr 1fr;gap:0.85rem;
}
@media (max-width:639px) { .ct-row-2 { grid-template-columns:1fr; } }

.ct-input {
  width:100%;
  background:#F8F6F2;border:1.5px solid #E5E7EB;border-radius:14px;
  padding:0.875rem 1.1rem;
  font:500 0.88rem/1 'Inter Tight',sans-serif;color:#0A1628;
  outline:none;appearance:none;-webkit-appearance:none;
  transition:border-color 0.2s,box-shadow 0.2s,background 0.2s;
  display:block;box-sizing:border-box;
}
.ct-input::placeholder { color:#9CA3AF; }
.ct-input:focus {
  border-color:#0054DF;
  box-shadow:0 0 0 3px rgba(0,84,223,0.1);
  background:#fff;
}
.ct-textarea { resize:vertical;min-height:110px;line-height:1.5; }

/* Select wrapper */
.ct-select-wrap { position:relative; }
.ct-select { cursor:pointer;padding-right:2.5rem; }
.ct-select-chevron {
  position:absolute;right:1rem;top:50%;transform:translateY(-50%);
  width:16px;height:16px;color:#9CA3AF;pointer-events:none;
}

/* Form layout spacing */
form { display:flex;flex-direction:column;gap:0.85rem; }

/* Submit button */
.ct-submit {
  width:100%;border-radius:999px;
  background:#F96B2B;color:#fff;border:none;cursor:pointer;
  padding:1.05rem 2rem;
  font:700 0.92rem/1 'Inter Tight',sans-serif;
  box-shadow:0 16px 36px rgba(249,107,43,0.28);
  transition:opacity 0.2s,transform 0.2s;
  margin-top:0.4rem;
}
.ct-submit:hover { opacity:0.9;transform:translateY(-1px); }
.ct-submit:disabled { opacity:0.6;cursor:not-allowed;transform:none; }
.ct-submit-note {
  font:500 0.72rem/1 'Inter Tight',sans-serif;
  color:#9CA3AF;text-align:center;margin:0.65rem 0 0;
}
.ct-error-msg {
  font:500 0.8rem/1.5 'Inter Tight',sans-serif;
  color:#EF4444;margin-top:0.75rem;text-align:center;
}
.ct-error-msg a { color:#0054DF;text-decoration:underline; }

/* Success state */
.ct-success {
  flex-direction:column;align-items:center;text-align:center;
  padding:2.5rem 1rem;
}
.ct-success-icon {
  width:4.5rem;height:4.5rem;border-radius:50%;
  background:rgba(0,84,223,0.1);
  display:flex;align-items:center;justify-content:center;
}
.ct-success-title {
  font-family:'Oswald',sans-serif;font-weight:700;
  font-size:1.75rem;color:#0A1628;margin:1.25rem 0 0.5rem;
}
.ct-success-body {
  font:500 0.95rem/1.6 'Inter Tight',sans-serif;
  color:#6B7280;margin:0 0 0.75rem;
}
.ct-success-call {
  font:500 0.82rem/1 'Inter Tight',sans-serif;
  color:#9CA3AF;margin:0;
}
.ct-success-call a { color:#0054DF;text-decoration:none;font-weight:700; }

/* ─── Contact info card ─── */
.ct-info-col { position:sticky;top:6rem;align-self:start; }
@media (max-width:767px) { .ct-info-col { position:static; } }

.ct-info-card {
  background:#F8F6F2;border-radius:22px;
  padding:1.75rem 1.5rem;
  border:1px solid rgba(10,22,40,0.07);
}
