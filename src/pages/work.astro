</BaseLayout>

<!-- ─────────────── CDN ─────────────── -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
/* ── Hero particle canvas ── */
(function () {
  var canvas = document.getElementById('wk-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W, H, pts;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  pts = Array.from({ length: 65 }, function () {
    return { x: Math.random() * W, y: Math.random() * H, vx: (Math.random() - 0.5) * 0.28, vy: (Math.random() - 0.5) * 0.28, r: Math.random() * 1.4 + 0.6 };
  });
  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (var i = 0; i < pts.length; i++) {
      var p = pts[i];
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(142,183,255,0.5)'; ctx.fill();
      for (var j = i + 1; j < pts.length; j++) {
        var q = pts[j];
        var dx = p.x - q.x, dy = p.y - q.y, d = Math.sqrt(dx * dx + dy * dy);
        if (d < 120) {
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = 'rgba(0,84,223,' + (0.14 * (1 - d / 120)) + ')';
          ctx.lineWidth = 0.6; ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ── Michoacana screenshot parallax on scroll ── */
(function () {
  if (typeof window === 'undefined') return;
  var mainImg = document.querySelector('.mich-screen-main');
  if (!mainImg) return;
  window.addEventListener('scroll', function () {
    var rect = mainImg.getBoundingClientRect();
    var progress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
    var clamp = Math.max(0, Math.min(1, progress));
    mainImg.style.transform = 'perspective(1200px) rotateX(' + ((1 - clamp) * -6) + 'deg) translateY(' + (clamp * -18) + 'px)';
  }, { passive: true });
})();

/* ── Project card screenshot hover swap ── */
(function () {
  document.querySelectorAll('.proj-card').forEach(function (card) {
    var mainImg = card.querySelector('.proj-main-img');
    var peeks   = card.querySelectorAll('.proj-peek img');
    if (!mainImg || !peeks.length) return;
    var originalSrc = mainImg.src;
    peeks.forEach(function (peek) {
      peek.parentElement.addEventListener('mouseenter', function () {
        mainImg.style.opacity = '0';
        setTimeout(function () {
          mainImg.src = peek.src;
          mainImg.style.opacity = '1';
        }, 120);
      });
      peek.parentElement.addEventListener('mouseleave', function () {
        mainImg.style.opacity = '0';
        setTimeout(function () {
          mainImg.src = originalSrc;
          mainImg.style.opacity = '1';
        }, 120);
      });
    });
  });
})();

/* ── GSAP ── */
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  /* hero */
  var heroTL = gsap.timeline({ defaults: { ease: 'power3.out' } });
  heroTL
    .fromTo('.wk-eyebrow-pill', { opacity:0, y:18 }, { opacity:1, y:0, duration:0.55 })
    .fromTo('.wk-h1-line',      { opacity:0, y:44 }, { opacity:1, y:0, duration:0.85, stagger:0.12 }, '-=0.1')
    .fromTo('.wk-hero-sub',     { opacity:0, y:22 }, { opacity:1, y:0, duration:0.65 }, '-=0.45')
