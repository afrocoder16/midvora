    <!-- Bottom note -->
    <p class="proj-note proj-reveal" style="--card-delay:0.3s">
      Every one of these started with a free 24-hour sample. Yours can too. &nbsp;
      <a href="/contact">Start now →</a>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 4 — CTA
═══════════════════════════════════════════════ -->
<section class="wk-cta relative overflow-hidden" style="background:#050e1c;padding:7rem 0 8rem;text-align:center;">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:70vw;height:70vw;max-width:54rem;max-height:54rem;background:radial-gradient(circle,rgba(249,107,43,0.2) 0%,rgba(0,84,223,0.1) 45%,transparent 70%);filter:blur(64px);"></div>
    <div class="wk-cta-grid"></div>
  </div>
  <div class="wk-deco-q wk-dq-1" aria-hidden="true">?</div>
  <div class="wk-deco-q wk-dq-2" aria-hidden="true">?</div>
  <div class="relative z-10 mx-auto max-w-3xl px-5">
    <div class="wk-cta-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F96B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
    </div>
    <h2 class="wk-cta-h2">Want to be<br/><span class="wk-cta-accent">featured here?</span></h2>
