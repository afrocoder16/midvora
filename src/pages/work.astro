    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:72px 72px;"></div>
    <div style="position:absolute;top:-10%;right:-5%;width:40rem;height:32rem;background:radial-gradient(circle,rgba(0,84,223,0.1) 0%,transparent 65%);filter:blur(64px);"></div>
    <div style="position:absolute;bottom:-8%;left:-4%;width:36rem;height:28rem;background:radial-gradient(circle,rgba(249,107,43,0.08) 0%,transparent 65%);filter:blur(64px);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8" style="padding-top:6rem;padding-bottom:7rem;">

    <!-- Section heading -->
