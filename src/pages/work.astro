          <div class="proj-card-specs">
            <div class="proj-spec"><span class="proj-spec-n">6</span><span class="proj-spec-l">Days live</span></div>
            <div class="proj-spec-sep"></div>
            <div class="proj-spec"><span class="proj-spec-n">44+</span><span class="proj-spec-l">Years serving MN</span></div>
            <div class="proj-spec-sep"></div>
            <div class="proj-spec"><span class="proj-spec-n">$0</span><span class="proj-spec-l">Up front</span></div>
          </div>
        </div>
      </div>

      <!-- ── CARD 3: SABOR ── -->
      <div class="proj-card proj-reveal" style="--card-delay:0.25s">
        <div class="proj-card-screens">
          <div class="proj-main-screen">
            <div class="proj-chrome">
              <div class="proj-chrome-dots"><span></span><span></span><span></span></div>
              <div class="proj-chrome-url">Sample Preview</div>
            </div>
            <div class="proj-img-wrap">
