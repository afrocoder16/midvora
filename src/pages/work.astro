        <div class="proj-card-screens">
          <div class="proj-main-screen">
            <div class="proj-chrome">
              <div class="proj-chrome-dots"><span></span><span></span><span></span></div>
              <div class="proj-chrome-url">Sample Preview</div>
            </div>
            <div class="proj-img-wrap">
              <img src="/work/photoworks.png" alt="PhotoWorks website" class="proj-main-img" loading="lazy"/>
            </div>
          </div>
          <div class="proj-peek-row">
            <div class="proj-peek">
              <img src="/work/photoworks2.png" alt="PhotoWorks — services page" loading="lazy"/>
            </div>
            <div class="proj-peek">
              <img src="/work/photoworks3.png" alt="PhotoWorks — portfolio" loading="lazy"/>
            </div>
          </div>
          <div class="proj-card-hover-overlay">
            <span class="proj-view-btn">View project →</span>
          </div>
        </div>
        <div class="proj-card-meta">
          <div class="proj-card-tags">
            <span class="proj-tag proj-tag-blue">Photography</span>
            <span class="proj-tag proj-tag-ghost">Sample</span>
          </div>
