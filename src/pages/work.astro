---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Our Work — Midvora">

<!-- ═══════════════════════════════════════════════
     SECTION 1 — HERO
═══════════════════════════════════════════════ -->
<section class="wk-hero relative overflow-hidden" style="background:#050e1c;min-height:88vh;display:flex;align-items:center;justify-content:center;">

  <canvas id="wk-canvas" class="pointer-events-none absolute inset-0" style="opacity:0.45;"></canvas>

  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div style="position:absolute;top:-18%;left:-8%;width:65vw;height:65vw;max-width:52rem;max-height:52rem;background:radial-gradient(circle,rgba(0,84,223,0.22) 0%,transparent 62%);filter:blur(64px);"></div>
    <div style="position:absolute;bottom:-14%;right:-6%;width:50vw;height:50vw;max-width:42rem;max-height:42rem;background:radial-gradient(circle,rgba(249,107,43,0.16) 0%,transparent 62%);filter:blur(56px);"></div>
    <div class="wk-hero-grid"></div>
    <div class="wk-beam"></div>
  </div>

  <div class="wk-orbit-ring pointer-events-none" aria-hidden="true">
    <div class="wk-orbit-dot wk-orbit-dot-1"></div>
    <div class="wk-orbit-dot wk-orbit-dot-2"></div>
    <div class="wk-orbit-dot wk-orbit-dot-3"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl px-5 text-center">
    <div class="wk-eyebrow-pill">
      <span class="wk-live-dot"></span>
      <span>Our Work</span>
    </div>
    <h1 class="wk-hero-h1">
      <span class="wk-h1-line">Real businesses.</span>
      <span class="wk-h1-line wk-h1-accent">Real results.</span>
    </h1>
    <p class="wk-hero-sub">
      Every project starts with a free sample.<br class="hidden md:block"/>
      Here's what happens when clients say&nbsp;<em class="wk-yes">yes.</em>
    </p>
    <div class="wk-hero-stats">
      <div class="wk-stat-chip wk-stat-chip-blue"><span class="wk-stat-n">24h</span><span class="wk-stat-l">First sample</span></div>
      <div class="wk-stat-chip wk-stat-chip-orange"><span class="wk-stat-n">$0</span><span class="wk-stat-l">To see it</span></div>
      <div class="wk-stat-chip wk-stat-chip-ghost"><span class="wk-stat-n">100%</span><span class="wk-stat-l">Custom</span></div>
    </div>
  </div>

  <div class="wk-scroll-cue">
    <div class="wk-scroll-track"><div class="wk-scroll-thumb"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 2 — FEATURED: LA MICHOACANA ELITE
═══════════════════════════════════════════════ -->
<section class="mich-section relative overflow-hidden">

  <!-- Deep dark background with brand-accurate warm cream -->
  <div class="mich-bg-layer" aria-hidden="true">
    <div class="mich-glow-pink"></div>
    <div class="mich-glow-green"></div>
    <div class="mich-noise"></div>
  </div>

  <!-- ── TOP: Case Study label ── -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8">
    <div class="mich-case-label">
      <div class="mich-case-line"></div>
      <span>Featured Case Study</span>
      <div class="mich-case-line"></div>
    </div>
  </div>

  <!-- ── HERO BAND: big title + tag ── -->
  <div class="relative z-10 mich-title-band">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="mich-title-row">
        <div class="mich-title-left">
          <div class="mich-project-tag">
            <span class="mich-tag-dot"></span>
            Ice Cream Shop
          </div>
          <h2 class="mich-title">La Michoacana<br/><em class="mich-title-em">Elite</em></h2>
          <p class="mich-subtitle">A full-stack interactive experience — bold brand, live ordering, signature drink builder, and bilingual support. Built in 24 hours. Launched in 7 days.</p>
        </div>
        <div class="mich-title-right">
          <div class="mich-stat-block">
            <div class="mich-stat"><span class="mich-stat-n">7</span><span class="mich-stat-l">Days to launch</span></div>
            <div class="mich-stat-div"></div>
            <div class="mich-stat"><span class="mich-stat-n">24h</span><span class="mich-stat-l">Sample delivered</span></div>
            <div class="mich-stat-div"></div>
            <div class="mich-stat"><span class="mich-stat-n">$0</span><span class="mich-stat-l">Up front</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── SCREENSHOT SHOWCASE ── -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 mich-screens-wrap">

    <!-- Main hero screenshot — full width, tilted -->
    <div class="mich-screen-main mich-reveal">
      <div class="mich-browser-chrome">
        <div class="mich-dots"><span style="background:#FF5F57"></span><span style="background:#FFBD2E"></span><span style="background:#28CA41"></span></div>
        <div class="mich-url-bar">Sample Preview</div>
        <div class="mich-live-badge"><span class="mich-live-dot-green"></span>Sample</div>
      </div>
      <div class="mich-screen-img-wrap">
        <img src="/work/michoacana.png" alt="La Michoacana Elite — hero section" class="mich-screen-img" loading="lazy"/>
        <div class="mich-screen-shimmer"></div>
      </div>
    </div>

    <!-- Three detail shots in a creative asymmetric grid -->
    <div class="mich-detail-grid">

      <!-- Shot 2: Menu page — large left -->
      <div class="mich-detail-card mich-detail-large mich-reveal" style="--delay:0.1s">
        <div class="mich-detail-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20"/></svg>
          Interactive Menu
        </div>
        <img src="/work/michoacana2.png" alt="La Michoacana Elite — menu page" class="mich-detail-img" loading="lazy"/>
        <div class="mich-detail-overlay">
          <p class="mich-detail-caption">Category filters, live pricing, and a design built around their vibrant brand palette.</p>
        </div>
      </div>

      <!-- Right column: two stacked -->
      <div class="mich-detail-col-right">

        <!-- Shot 3: Drink builder -->
        <div class="mich-detail-card mich-reveal" style="--delay:0.2s">
          <div class="mich-detail-label">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Drink Builder
          </div>
          <img src="/work/michoacana3.png" alt="La Michoacana Elite — drink builder" class="mich-detail-img" loading="lazy"/>
          <div class="mich-detail-overlay">
            <p class="mich-detail-caption">Build-your-own feature with real-time preview and ingredient selection.</p>
          </div>
        </div>

        <!-- Shot 4: Spin wheel -->
        <div class="mich-detail-card mich-reveal" style="--delay:0.3s">
          <div class="mich-detail-label">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2v10l4.5 4.5"/></svg>
            Pick For Me Wheel
          </div>
          <img src="/work/michoacana4.png" alt="La Michoacana Elite — spin wheel feature" class="mich-detail-img" loading="lazy"/>
          <div class="mich-detail-overlay">
            <p class="mich-detail-caption">Shake your phone or spin — the wheel picks tonight's craving.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Deliverables strip -->
    <div class="mich-chips-strip mich-reveal" style="--delay:0.15s">
      {[
        { icon: '🎨', label: 'Custom brand design' },
        { icon: '🍦', label: 'Interactive menu' },
        { icon: '🎯', label: 'Drink builder' },
        { icon: '🌀', label: 'Pick For Me wheel' },
        { icon: '🌐', label: 'Bilingual support' },
        { icon: '📱', label: 'Mobile-first' },
        { icon: '🛒', label: 'Online ordering' },
        { icon: '⚡', label: 'Live in 7 days' },
      ].map(chip => (
        <div class="mich-chip">
          <span class="mich-chip-icon">{chip.icon}</span>
          <span>{chip.label}</span>
        </div>
      ))}
    </div>

    <!-- Bottom CTA row -->
    <div class="mich-bottom-row mich-reveal" style="--delay:0.2s">
      <div class="mich-quote">
        <svg class="mich-quote-icon" viewBox="0 0 40 32" fill="none"><path d="M0 32V20C0 8.667 6.667 2 20 0l2.667 4C16.889 5.333 13.778 8.444 13.333 13.333H20V32H0zm20 0V20C20 8.667 26.667 2 40 0l2.667 4C36.889 5.333 33.778 8.444 33.333 13.333H40V32H20z" fill="currentColor"/></svg>
        <p>We wanted something as bold and fun as we are. Midvora delivered in a day. We couldn't believe it was ours.</p>
        <p class="mich-quote-attr">— La Michoacana Elite, Marshall MN</p>
      </div>
      <a href="/contact" class="mich-cta-btn">
        Get your free sample
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 3 — MORE PROJECTS (real screenshots)
═══════════════════════════════════════════════ -->
