            <div class="proj-spec"><span class="proj-spec-n">7</span><span class="proj-spec-l">Days live</span></div>
            <div class="proj-spec-sep"></div>
            <div class="proj-spec"><span class="proj-spec-n">4</span><span class="proj-spec-l">Pages built</span></div>
            <div class="proj-spec-sep"></div>
            <div class="proj-spec"><span class="proj-spec-n">$0</span><span class="proj-spec-l">Up front</span></div>
