<!-- ─────────────── CDN scripts ─────────────── -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
/* ── FAQ accordion ── */
(function () {
  document.querySelectorAll('.svc-faq-item').forEach(function (item) {
    var btn  = item.querySelector('.svc-faq-q');
    var body = item.querySelector('.svc-faq-body');
    var chev = item.querySelector('.svc-faq-chevron');
    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      /* close all */
      document.querySelectorAll('.svc-faq-item').forEach(function (el) {
        el.querySelector('.svc-faq-q').setAttribute('aria-expanded', 'false');
        el.querySelector('.svc-faq-body').style.maxHeight = '0';
        el.querySelector('.svc-faq-chevron').style.transform = 'rotate(0deg)';
        el.classList.remove('svc-faq-open');
      });
      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
        chev.style.transform = 'rotate(180deg)';
        item.classList.add('svc-faq-open');
      }
    });
  });
})();

/* ── Add-on card 3D tilt ── */
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  document.querySelectorAll('.addon-tilt').forEach(function (card) {
    card.addEventListener('mousemove', function (e) {
      var r = card.getBoundingClientRect();
      var x = (e.clientX - r.left) / r.width  - 0.5;
      var y = (e.clientY - r.top)  / r.height - 0.5;
      card.style.transform = 'perspective(600px) rotateY(' + (x * 14) + 'deg) rotateX(' + (-y * 14) + 'deg) translateZ(8px)';
    });
    card.addEventListener('mouseleave', function () {
      card.style.transform = 'perspective(600px) rotateY(0deg) rotateX(0deg) translateZ(0)';
    });
  });
})();

/* ── GSAP scroll animations ── */
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  /* hero */
  var heroTL = gsap.timeline({ defaults: { ease: 'power3.out' } });
  heroTL
    .fromTo('.svc-hero-eyebrow', { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.55 })
    .fromTo('.svc-h1-line',      { opacity: 0, y: 44 }, { opacity: 1, y: 0, duration: 0.85, stagger: 0.1 }, '-=0.1')
    .fromTo('.svc-hero-sub',     { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.65 }, '-=0.45')
    .fromTo('.svc-price-pill',   { opacity: 0, y: 20, scale: 0.9 }, { opacity: 1, y: 0, scale: 1, duration: 0.5, stagger: 0.12 }, '-=0.3')
    .fromTo('.svc-hero-guarantee',{ opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.45 }, '-=0.2');

  /* section headings */
  document.querySelectorAll('.svc-section-head').forEach(function (el) {
    gsap.fromTo(el,
      { opacity: 0, y: 32 },
      { opacity: 1, y: 0, duration: 0.75, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 82%', once: true } }
    );
  });

  /* package cards */
  gsap.fromTo('.svc-pkg-card',
    { opacity: 0, y: 50, scale: 0.96 },
    { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'power2.out', stagger: 0.15,
      scrollTrigger: { trigger: '.svc-pkg-grid', start: 'top 80%', once: true } }
  );

  /* addon cards */
  gsap.fromTo('.svc-addon-card',
    { opacity: 0, y: 36 },
    { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.08,
      scrollTrigger: { trigger: '.svc-addon-grid', start: 'top 80%', once: true } }
  );

  /* care cards */
  gsap.fromTo('.svc-care-card',
    { opacity: 0, y: 44, scale: 0.97 },
    { opacity: 1, y: 0, scale: 1, duration: 0.75, ease: 'power2.out', stagger: 0.18,
      scrollTrigger: { trigger: '.svc-care-grid', start: 'top 80%', once: true } }
  );

  /* bundle cards */
  gsap.fromTo('.svc-bundle-card',
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.15,
      scrollTrigger: { trigger: '.svc-bundle-grid', start: 'top 80%', once: true } }
  );

  /* premium cards */
  gsap.fromTo('.svc-premium-card',
    { opacity: 0, x: -20 },
    { opacity: 1, x: 0, duration: 0.6, ease: 'power2.out', stagger: 0.12,
      scrollTrigger: { trigger: '.svc-premium-grid', start: 'top 80%', once: true } }
  );

  /* faq items */
  gsap.fromTo('.svc-faq-item',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', stagger: 0.08,
      scrollTrigger: { trigger: '#faq-list', start: 'top 80%', once: true } }
  );

  /* cta */
  gsap.fromTo('.svc-cta-headline',
    { opacity: 0, y: 36 },
    { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '.svc-cta', start: 'top 75%', once: true } }
  );
  gsap.fromTo('.svc-cta-btns',
    { opacity: 0, y: 20 },
    { opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', delay: 0.25,
      scrollTrigger: { trigger: '.svc-cta', start: 'top 75%', once: true } }
  );

  /* Builder section animations */
  gsap.fromTo('.byo-header',
    { opacity: 0, y: 36 },
    { opacity: 1, y: 0, duration: 0.75, ease: 'power2.out',
      scrollTrigger: { trigger: '#build-your-own', start: 'top 80%', once: true } }
  );
  gsap.fromTo('.byo-step',
    { opacity: 0, y: 40 },
    { opacity: 1, y: 0, duration: 0.65, ease: 'power2.out', stagger: 0.15,
      scrollTrigger: { trigger: '.byo-step-1', start: 'top 82%', once: true } }
  );
  gsap.fromTo('.byo-nudge',
    { opacity: 0, y: 28 },
    { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out',
      scrollTrigger: { trigger: '.byo-nudge', start: 'top 85%', once: true } }
  );
})();

/* ── Builder state machine ── */
(function () {
  var state = { base: 295, features: [], monthly: 0 };

  /* ── Floating button visibility ── */
  var floatBtn = document.getElementById('byo-float-btn');
  var byoSection = document.getElementById('build-your-own');
  var bar = document.getElementById('byo-bar');

  if (floatBtn && byoSection) {
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        /* hide float btn when section is in view, show sticky bar */
        floatBtn.style.opacity = e.isIntersecting ? '0' : '1';
        floatBtn.style.pointerEvents = e.isIntersecting ? 'none' : 'auto';
        if (bar) {
          bar.classList.toggle('byo-bar-visible', e.isIntersecting);
        }
      });
    }, { threshold: 0.05 });
    obs.observe(byoSection);
  }

  /* ── Render total ── */
  var totalEl   = document.getElementById('byo-total-display');
  var monthlyEl = document.getElementById('byo-monthly-display');
  var ctaEl     = document.getElementById('byo-bar-cta');

  function getTotal() { return state.base + state.features.reduce(function (a, b) { return a + b; }, 0); }

  var currentDisplayed = 295;
  function updateDisplay() {
    var target = getTotal();
    if (typeof gsap !== 'undefined') {
      gsap.to({ val: currentDisplayed }, {
        val: target, duration: 0.45, ease: 'power2.out',
        onUpdate: function () { if (totalEl) totalEl.textContent = '$' + Math.round(this.targets()[0].val); },
        onComplete: function () { currentDisplayed = target; }
      });
    } else {
      if (totalEl) totalEl.textContent = '$' + target;
      currentDisplayed = target;
    }
    if (monthlyEl) {
      if (state.monthly > 0) {
        monthlyEl.textContent = '+ $' + state.monthly + '/mo';
        monthlyEl.style.display = 'inline';
      } else {
        monthlyEl.style.display = 'none';
      }
    }
    if (ctaEl) {
      ctaEl.href = '/contact?package=custom&total=' + target + '&monthly=' + state.monthly;
    }
  }

  /* ── Base selection ── */
  document.querySelectorAll('.byo-base-card,.byo-care-card').forEach(function (card) {
    card.addEventListener('click', function () {
      var type = card.dataset.type;
      var price = parseInt(card.dataset.price, 10);
      var siblings = document.querySelectorAll('[data-type="' + type + '"]');
      siblings.forEach(function (s) { s.classList.remove('byo-selected'); });
      card.classList.add('byo-selected');
      if (type === 'base') state.base = price;
      if (type === 'care') state.monthly = price;
      updateDisplay();
    });
  });

  /* ── Feature toggles ── */
  document.querySelectorAll('.byo-feat-card').forEach(function (card) {
    card.addEventListener('click', function () {
      var price = parseInt(card.dataset.price, 10);
      var active = card.classList.toggle('byo-feat-active');
      if (active) {
        state.features.push(price);
      } else {
        var idx = state.features.indexOf(price);
        if (idx > -1) state.features.splice(idx, 1);
      }
      updateDisplay();
    });
  });

  updateDisplay();
})();
</script>

