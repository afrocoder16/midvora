---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Services & Pricing — Midvora">

<!-- ═══════════════════════════════════════════════
     SECTION 1 — HERO
═══════════════════════════════════════════════ -->
<section class="svc-hero relative overflow-hidden">

  <!-- Background layers -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <!-- Cream base + subtle noise texture -->
    <div class="svc-hero-noise"></div>
    <!-- Blue accent top-right -->
    <div style="position:absolute;top:-20%;right:-8%;width:52vw;height:52vw;max-width:40rem;max-height:40rem;background:radial-gradient(circle,rgba(0,84,223,0.09) 0%,transparent 65%);filter:blur(64px);"></div>
    <!-- Orange warmth bottom-left -->
    <div style="position:absolute;bottom:-14%;left:-5%;width:44vw;height:44vw;max-width:36rem;max-height:36rem;background:radial-gradient(circle,rgba(249,107,43,0.1) 0%,transparent 65%);filter:blur(56px);"></div>
  </div>

  <div class="svc-hero-inner relative z-10 mx-auto max-w-5xl px-5 sm:px-8">

    <!-- Eyebrow -->
    <div class="svc-hero-eyebrow">
      <span class="svc-blink-dot"></span>
      <span>Simple, Honest Pricing</span>
    </div>

    <!-- Headline -->
    <h1 class="svc-hero-headline">
      <span class="svc-h1-line">Less than</span>
      <span class="svc-h1-line">you think.</span>
      <span class="svc-h1-line"><span class="svc-hero-accent">Way more</span> than</span>
      <span class="svc-h1-line">you'd expect.</span>
    </h1>

    <!-- Sub -->
    <p class="svc-hero-sub">
      Every price is upfront. No hourly rates. No surprises.<br class="hidden sm:block"/>
      You know exactly what you're paying before we start.
    </p>

    <!-- Price showcase row — the "different" element vs work page -->
    <div class="svc-price-row">
      <div class="svc-price-pill svc-pp-blue">
        <span class="svc-pp-amount">$700</span>
        <span class="svc-pp-label">Starter</span>
      </div>
      <div class="svc-price-connector" aria-hidden="true">→</div>
      <div class="svc-price-pill svc-pp-orange">
        <span class="svc-pp-amount">$1,300</span>
        <span class="svc-pp-label">Growth</span>
      </div>
      <div class="svc-price-connector" aria-hidden="true">→</div>
      <div class="svc-price-pill svc-pp-dark">
        <span class="svc-pp-amount">$2,000</span>
        <span class="svc-pp-label">Premium</span>
      </div>
    </div>

    <!-- No contracts guarantee line -->
    <p class="svc-hero-guarantee">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      Free sample first · No payment until you approve · No contracts
    </p>

    <!-- Scroll cue (hidden mobile) -->
    <div class="svc-scroll-cue" aria-hidden="true">
      <div class="svc-scroll-line"></div>
      <span>Scroll to explore</span>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 2 — WEBSITE PACKAGES
═══════════════════════════════════════════════ -->
<section id="svc-packages" class="svc-packages relative overflow-hidden" style="background:#fff;padding:7rem 0 8rem;">

  <!-- Background texture -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(0,84,223,0.04) 1px,transparent 1px);background-size:32px 32px;"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8">
    <div class="svc-section-head text-center">
      <p class="svc-eyebrow">Website Packages</p>
      <h2 class="svc-section-h2">Pick your starting point.</h2>
      <p class="svc-section-sub">Every package starts with a free sample, zero risk, no payment until you approve.</p>
    </div>

    <div class="svc-pkg-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3.5rem;align-items:start;">

      <!-- CARD 1: Starter -->
      <div class="svc-pkg-card">
        <div class="svc-pkg-tag" style="background:rgba(0,84,223,0.1);color:#0054DF;">Get Online</div>
        <div class="svc-pkg-price-row">
          <span class="svc-pkg-price">$700</span>
          <span class="svc-pkg-cycle">one-time</span>
        </div>
        <p class="svc-pkg-name">Starter</p>
        <p class="svc-pkg-desc">Perfect for new businesses that need to get online fast with a clean, professional look.</p>
        <ul class="svc-pkg-list">
          {[
            'Custom 5-page website',
            'Mobile-ready on all phones',
            'Contact form + Google Maps',
            'SSL security included',
            'Google Business Profile setup — FREE',
            'Live in 7 days',
          ].map(f => (
            <li class="svc-pkg-item svc-check-blue">
              <svg class="svc-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="svc-pkg-cta" style="background:#0A1628;color:#fff;">Get Free Sample</a>
      </div>

      <!-- CARD 2: Growth (featured) -->
      <div class="svc-pkg-card svc-pkg-featured" style="position:relative;margin-top:-1.5rem;">
        <div class="svc-popular-badge">Most Popular</div>
        <div class="svc-pkg-tag" style="background:rgba(249,107,43,0.1);color:#F96B2B;">Grow Faster</div>
        <div class="svc-pkg-price-row">
          <span class="svc-pkg-price" style="color:#F96B2B;">$1,300</span>
          <span class="svc-pkg-cycle">one-time</span>
        </div>
        <p class="svc-pkg-name">Growth</p>
        <p class="svc-pkg-desc">For restaurants, salons, and service businesses ready to take orders and bookings online.</p>
        <ul class="svc-pkg-list">
          {[
            'Everything in Starter',
            'Up to 8 pages',
            'Online ordering (Square / Toast)',
            'Update menu from your phone',
            'English + Spanish language option',
            'SEO management — FREE 3 months',
            'Live in 10 days',
          ].map(f => (
            <li class="svc-pkg-item svc-check-orange">
              <svg class="svc-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="svc-pkg-cta" style="background:#F96B2B;color:#fff;">Get Free Sample</a>
      </div>

      <!-- CARD 3: Premium -->
      <div class="svc-pkg-card">
        <div class="svc-pkg-tag" style="background:#0A1628;color:#fff;">Go All In</div>
        <div class="svc-pkg-price-row">
          <span class="svc-pkg-price">$2,000</span>
          <span class="svc-pkg-cycle">one-time</span>
        </div>
        <p class="svc-pkg-name">Premium</p>
        <p class="svc-pkg-desc">For established businesses ready to dominate their local market with a full digital presence.</p>
        <ul class="svc-pkg-list">
          {[
            'Everything in Growth',
            'Up to 12 pages',
            'Interactive features + loyalty cards',
            'Your own admin panel',
            'Photography session included',
            'Advanced SEO + analytics',
            'FREE 3 months SEO + review management',
          ].map(f => (
            <li class="svc-pkg-item svc-check-blue">
              <svg class="svc-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="svc-pkg-cta" style="background:#0A1628;color:#fff;">Get Free Sample</a>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 3 — ADD-ONS (3D tilt cards)
═══════════════════════════════════════════════ -->
<section class="svc-addons relative overflow-hidden" style="background:#F0F4FF;padding:7rem 0 8rem;">

  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div style="position:absolute;top:-8%;right:-4%;width:32rem;height:32rem;background:radial-gradient(circle,rgba(0,84,223,0.1) 0%,transparent 65%);filter:blur(48px);"></div>
    <div style="position:absolute;bottom:-6%;left:-3%;width:28rem;height:28rem;background:radial-gradient(circle,rgba(249,107,43,0.1) 0%,transparent 65%);filter:blur(48px);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8">
    <div class="svc-section-head text-center">
      <p class="svc-eyebrow">Power It Up</p>
      <h2 class="svc-section-h2">Add what you need.<br/>Skip what you don't.</h2>
    </div>

    <div class="svc-addon-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:3.5rem;">
      {[
        { icon: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z', name: 'Google Business Profile', price: '$125', color: '#0054DF' },
        { icon: 'M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01M7.5 2h9a5.5 5.5 0 0 1 5.5 5.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2z', name: 'Social Media Kit', price: '$175', color: '#F96B2B' },
        { icon: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2zM12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8z', name: 'Photography Session', price: '$249', color: '#0054DF' },
        { icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5', name: 'Logo & Brand Kit', price: '$300', color: '#F96B2B' },
        { icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 10H2M12 10v9', name: 'Email Marketing Setup', price: '$175', color: '#0054DF' },
        { icon: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z', name: 'QR Code Menu', price: '$49', color: '#F96B2B' },
        { icon: 'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z', name: 'Event Website', price: '$250', color: '#0054DF' },
        { icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z', name: 'Call Tracking Setup', price: '$99', color: '#F96B2B' },
      ].map((a, i) => (
        <div class="svc-addon-card addon-tilt" data-index={i}>
          <div class="svc-addon-icon" style={`background:rgba(${a.color === '#0054DF' ? '0,84,223' : '249,107,43'},0.1);`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={a.color} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d={a.icon}/>
            </svg>
          </div>
          <p class="svc-addon-name">{a.name}</p>
          <p class="svc-addon-price" style={`color:${a.color};`}>{a.price}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 4 — MONTHLY CARE (dark, glowing)
═══════════════════════════════════════════════ -->
<section class="svc-care relative overflow-hidden" style="background:#050e1c;padding:7rem 0 8rem;">

  <!-- Animated orbs -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="svc-orb svc-orb-1"></div>
    <div class="svc-orb svc-orb-2"></div>
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.04) 1px,transparent 1px);background-size:28px 28px;opacity:0.4;"></div>
  </div>

  <!-- Rotating ring decoration -->
  <div class="svc-ring-wrap pointer-events-none" aria-hidden="true">
    <div class="svc-ring svc-ring-1"></div>
    <div class="svc-ring svc-ring-2"></div>
    <div class="svc-ring svc-ring-3"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8">
    <div class="svc-section-head text-center">
      <p class="svc-eyebrow" style="color:#F96B2B;">Keep It Running</p>
      <h2 class="svc-section-h2" style="color:#fff;">We don't just build it.<br/>We take care of it.</h2>
      <p class="svc-section-sub" style="color:rgba(255,255,255,0.45);">Your website works 24/7. So does our monitoring.</p>
    </div>

    <div class="svc-care-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3.5rem;max-width:52rem;margin-left:auto;margin-right:auto;">

      <!-- Monthly Support -->
      <div class="svc-care-card">
        <p class="svc-care-name">Monthly Support</p>
        <div class="svc-care-price-row">
          <span class="svc-care-price">$50</span>
          <span class="svc-care-mo">/mo</span>
        </div>
        <ul class="svc-care-list">
          {[
            'Website maintenance + updates',
            'Security monitoring + patches',
            'Backups + uptime monitoring',
            'Content changes (text, photos, hours)',
          ].map(f => (
            <li class="svc-care-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#8EB7FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="svc-care-cta svc-care-cta-ghost">Get started</a>
      </div>

      <!-- Full Care -->
      <div class="svc-care-card svc-care-featured">
        <div class="svc-care-glow" aria-hidden="true"></div>
        <p class="svc-care-name">Full Care</p>
        <div class="svc-care-price-row">
          <span class="svc-care-price" style="color:#F96B2B;">$100</span>
          <span class="svc-care-mo">/mo</span>
        </div>
        <ul class="svc-care-list">
          {[
            'Everything in Monthly Support',
            'SEO management + monthly reports',
            'Social media management',
            'Review monitoring + responses',
            'Google Business Profile optimization',
          ].map(f => (
            <li class="svc-care-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#F96B2B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="/contact" class="svc-care-cta svc-care-cta-orange">Get started</a>
      </div>

    </div>

    <p class="text-center" style="color:rgba(255,255,255,0.32);font:500 0.82rem/1 'Inter Tight',sans-serif;margin-top:2rem;letter-spacing:0.06em;">No contracts. Cancel anytime.</p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 5 — BUNDLE DEALS
═══════════════════════════════════════════════ -->
<section class="svc-bundles relative overflow-hidden" style="background:#F8F6F2;padding:7rem 0 8rem;">

  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(10,22,40,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(10,22,40,0.03) 1px,transparent 1px);background-size:48px 48px;"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-5 sm:px-8">
    <div class="svc-section-head text-center">
      <p class="svc-eyebrow">Bundle &amp; Save</p>
      <h2 class="svc-section-h2">Get more. Pay less.</h2>
      <p class="svc-section-sub">Combine services and save, everything you need in one shot.</p>
    </div>

    <div class="svc-bundle-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3.5rem;">

      <!-- Bundle 1 -->
      <div class="svc-bundle-card">
        <p class="svc-bundle-name">Get Online</p>
        <p class="svc-bundle-includes">Starter website + Google Business Profile setup</p>
        <div class="svc-bundle-price-row">
          <span class="svc-bundle-price">$449</span>
          <span class="svc-bundle-save">Save $75</span>
        </div>
        <a href="/contact" class="svc-bundle-link" style="color:#0054DF;">Get started &rarr;</a>
      </div>

      <!-- Bundle 2 (featured) -->
      <div class="svc-bundle-card svc-bundle-featured">
        <div class="svc-bundle-top-accent"></div>
        <p class="svc-bundle-name">Digital Storefront</p>
        <p class="svc-bundle-includes">Growth website + GBP + photography + QR menu</p>
        <div class="svc-bundle-price-row">
          <span class="svc-bundle-price" style="color:#F96B2B;">$999</span>
          <span class="svc-bundle-save">Save $175</span>
        </div>
        <a href="/contact" class="svc-bundle-link" style="color:#F96B2B;">Get started &rarr;</a>
      </div>

      <!-- Bundle 3 (dark) -->
      <div class="svc-bundle-card svc-bundle-dark">
        <div class="svc-bundle-dark-glow" aria-hidden="true"></div>
        <p class="svc-bundle-name" style="color:#fff;">Full Digital Presence</p>
        <p class="svc-bundle-includes" style="color:rgba(255,255,255,0.55);">Premium site + GBP + social kit + photos + logo + email</p>
        <div class="svc-bundle-price-row">
          <span class="svc-bundle-price" style="color:#fff;">$2,200</span>
          <span class="svc-bundle-save" style="background:rgba(74,222,128,0.15);color:#4ade80;">Save $224</span>
        </div>
        <a href="/contact" class="svc-bundle-link" style="color:#F96B2B;">Get started &rarr;</a>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 6 — PREMIUM SERVICES (3D marquee style)
═══════════════════════════════════════════════ -->
<section class="svc-premium relative overflow-hidden" style="background:#fff;padding:7rem 0 8rem;">

  <!-- Subtle gradient top -->
  <div class="pointer-events-none absolute top-0 left-0 right-0" style="height:200px;background:linear-gradient(to bottom,rgba(240,244,255,0.8),transparent);" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8">
    <div class="svc-section-head text-center">
      <p class="svc-eyebrow">Going Bigger?</p>
      <h2 class="svc-section-h2">For businesses<br/>that need more.</h2>
    </div>

    <div class="svc-premium-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:3.5rem;max-width:52rem;margin-left:auto;margin-right:auto;">
      {[
        { name: 'Custom Web App', price: '$2,000–$5,000', desc: 'Booking systems, dashboards, inventory tools, and custom workflows built for your exact process.' },
        { name: 'E-Commerce Store', price: '$1,500–$3,000', desc: 'Full online store with payments, shipping, inventory, and a beautiful shopping experience.' },
        { name: 'Cybersecurity Audit', price: '$300–$2,500', desc: 'Security assessment from a Masters-level specialist. Know your vulnerabilities before attackers do.' },
        { name: 'Mobile App', price: 'Custom quote', desc: 'iPhone + Android apps for your business: loyalty, ordering, booking, or anything you need.' },
      ].map(s => (
        <div class="svc-premium-card">
          <div class="svc-premium-inner">
            <p class="svc-premium-name">{s.name}</p>
            <p class="svc-premium-price">{s.price}</p>
            <p class="svc-premium-desc">{s.desc}</p>
          </div>
          <div class="svc-premium-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center" style="color:#9CA3AF;font:500 0.85rem/1 'Inter Tight',sans-serif;margin-top:2.5rem;">
      All custom projects start with a free consultation call.
      <a href="/contact" style="color:#0054DF;font-weight:700;text-decoration:underline;text-underline-offset:3px;margin-left:0.25rem;">Book a call &rarr;</a>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 7 — FAQ (animated accordion)
═══════════════════════════════════════════════ -->
<section class="svc-faq relative" style="background:#F8F6F2;padding:7rem 0 8rem;">

  <div class="mx-auto max-w-2xl px-5 sm:px-8">
    <div class="svc-section-head text-center" style="margin-bottom:3.5rem;">
      <p class="svc-eyebrow">Questions</p>
      <h2 class="svc-section-h2">Everything you<br/>want to know.</h2>
    </div>

    <div class="svc-faq-list" id="faq-list">
      {[
        {
          q: 'How fast can you build my website?',
          a: 'Most websites are live in 5–10 days depending on the package. We can do rush delivery in under 5 days for an additional fee.',
        },
        {
          q: 'Do I own my website?',
          a: 'Yes. You own everything: the domain, the hosting account, the code, the content. We set it all up under your name.',
        },
        {
          q: 'What if I don\'t like the design?',
