  border-radius:16px;
  padding:0.85rem 1.25rem;
  min-width:90px;
  text-align:center;
  transition:transform 0.2s;
}
.svc-price-pill:hover { transform:translateY(-3px); }
.svc-pp-blue  { background:#0A1628;box-shadow:0 12px 32px rgba(10,22,40,0.2); }
.svc-pp-orange{ background:#F96B2B;box-shadow:0 12px 32px rgba(249,107,43,0.3); }
.svc-pp-dark  { background:#0A1628;box-shadow:0 12px 32px rgba(10,22,40,0.2); }
.svc-pp-amount {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.6rem;line-height:1;color:#fff;
}
.svc-pp-label {
  font:700 0.52rem/1 'Inter Tight',sans-serif;
  text-transform:uppercase;letter-spacing:0.14em;
  color:rgba(255,255,255,0.5);
  margin-top:0.3rem;
}
.svc-price-connector {
  font:700 1.1rem/1 'Inter Tight',sans-serif;
  color:rgba(10,22,40,0.2);
  flex-shrink:0;
}

/* Guarantee line */
.svc-hero-guarantee {
  display:flex;align-items:center;gap:0.55rem;
  font:600 0.8rem/1.4 'Inter Tight',sans-serif;
  color:#9CA3AF;
  margin:0;
}
.svc-hero-guarantee svg { flex-shrink:0;color:#0054DF; }
@media (max-width:767px) {
  .svc-hero-guarantee { justify-content:center;text-align:center; }
}

/* Scroll cue — hidden on mobile */
.svc-scroll-cue {
  display:flex;align-items:center;gap:0.75rem;
  margin-top:2.75rem;
  color:rgba(10,22,40,0.28);
  font:700 0.52rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.2em;text-transform:uppercase;
}
@media (max-width:767px) {
  .svc-scroll-cue { display:none; }
}
.svc-scroll-line {
  width:1px;height:32px;
  background:linear-gradient(to bottom,rgba(10,22,40,0.04),rgba(10,22,40,0.28));
  animation:svcScrollPulse 2s ease-in-out infinite;
}
@keyframes svcScrollPulse {
  0%,100%{opacity:0.3;transform:scaleY(1);}
  50%{opacity:1;transform:scaleY(1.15);}
}

/* ─────────────── SHARED SECTION ATOMS ─────────────── */
.svc-eyebrow {
  font:700 0.62rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.2em;
  text-transform:uppercase;
  color:#0054DF;
  display:block;
  margin-bottom:1rem;
}
.svc-section-h2 {
  font-family:'Oswald',sans-serif;
  font-weight:700;
  font-size:clamp(2rem,4.5vw,3.4rem);
  line-height:1;
  color:#0A1628;
  margin:0 0 1rem;
}
.svc-section-sub {
  font:500 1rem/1.6 'Inter Tight',sans-serif;
  color:#9CA3AF;
  max-width:32rem;
  margin:0 auto;
}

/* ─────────────── PACKAGE CARDS ─────────────── */
.svc-pkg-card {
  background:#fff;
  border-radius:24px;
  padding:2rem 1.75rem;
  border:1px solid #E5E7EB;
  display:flex;flex-direction:column;gap:0;
  transition:transform 0.28s,box-shadow 0.28s;
  box-shadow:0 4px 24px rgba(10,22,40,0.06);
}
.svc-pkg-card:hover {
  transform:translateY(-6px);
  box-shadow:0 24px 56px rgba(10,22,40,0.12);
}
.svc-pkg-featured {
  border:2px solid #F96B2B;
  box-shadow:0 8px 40px rgba(249,107,43,0.18);
}
.svc-popular-badge {
  position:absolute;top:-16px;left:50%;transform:translateX(-50%);
  background:#F96B2B;color:#fff;
  font:700 0.6rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.12em;text-transform:uppercase;
  padding:0.4rem 1rem;border-radius:999px;
  white-space:nowrap;
  box-shadow:0 6px 20px rgba(249,107,43,0.4);
}
.svc-pkg-tag {
  display:inline-block;
  font:700 0.58rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.12em;text-transform:uppercase;
  padding:0.38rem 0.8rem;border-radius:999px;
  margin-bottom:1.25rem;
  width:fit-content;
}
.svc-pkg-price-row {
  display:flex;align-items:baseline;gap:0.4rem;margin-bottom:0.25rem;
}
.svc-pkg-price {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:3.2rem;line-height:1;color:#0A1628;
}
.svc-pkg-cycle {
  font:500 0.8rem/1 'Inter Tight',sans-serif;
  color:#9CA3AF;
}
.svc-pkg-name {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.15rem;color:#0A1628;
  margin:0.5rem 0 0.75rem;
}
.svc-pkg-desc {
  font:500 0.9rem/1.55 'Inter Tight',sans-serif;
  color:#6B7280;
  margin-bottom:1.5rem;
}
.svc-pkg-list {
  list-style:none;padding:0;margin:0 0 1.75rem;
  display:flex;flex-direction:column;gap:0.65rem;
  flex:1;
}
.svc-pkg-item {
  display:flex;align-items:flex-start;gap:0.55rem;
  font:500 0.85rem/1.45 'Inter Tight',sans-serif;
  color:#374151;
}
.svc-check {
  width:16px;height:16px;flex-shrink:0;margin-top:1px;
}
.svc-check-blue .svc-check { color:#0054DF; }
.svc-check-orange .svc-check { color:#F96B2B; }
.svc-pkg-cta {
  display:block;text-align:center;
  border-radius:999px;padding:0.9rem 1.5rem;
  font:700 0.88rem/1 'Inter Tight',sans-serif;
  text-decoration:none;
  transition:opacity 0.2s,transform 0.2s;
  margin-top:auto;
}
.svc-pkg-cta:hover { opacity:0.88;transform:translateY(-1px); }

/* mobile stack */
@media (max-width:767px) {
  .svc-pkg-grid { grid-template-columns:1fr !important; }
  .svc-pkg-featured { margin-top:0 !important; }
}

/* ─────────────── ADD-ON CARDS ─────────────── */
.svc-addon-card {
  background:#fff;
  border-radius:18px;
  padding:1.5rem 1.25rem;
  border:1px solid rgba(10,22,40,0.07);
  text-align:center;
  transition:transform 0.22s,box-shadow 0.22s;
  box-shadow:0 2px 12px rgba(10,22,40,0.05);
  cursor:default;
}
.svc-addon-icon {
  width:48px;height:48px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 0.85rem;
}
.svc-addon-name {
  font:700 0.82rem/1.35 'Inter Tight',sans-serif;
  color:#0A1628;margin:0 0 0.4rem;
}
.svc-addon-price {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.3rem;
  margin:0;
}
@media (max-width:767px) {
  .svc-addon-grid { grid-template-columns:repeat(2,1fr) !important; }
}
@media (max-width:479px) {
  .svc-addon-grid { grid-template-columns:1fr 1fr !important; }
}

/* ─────────────── CARE CARDS ─────────────── */
.svc-orb {
  position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none;
}
.svc-orb-1 {
  top:-10%;left:-6%;
  width:50vw;height:50vw;max-width:44rem;max-height:44rem;
  background:radial-gradient(circle,rgba(0,84,223,0.25) 0%,transparent 65%);
}
.svc-orb-2 {
  bottom:-12%;right:-6%;
  width:44vw;height:44vw;max-width:38rem;max-height:38rem;
  background:radial-gradient(circle,rgba(249,107,43,0.18) 0%,transparent 65%);
}

/* Decorative rings */
.svc-ring-wrap {
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:800px;height:800px;pointer-events:none;
}
.svc-ring {
  position:absolute;border-radius:50%;
  border:1px solid rgba(255,255,255,0.04);
  top:50%;left:50%;transform:translate(-50%,-50%);
}
.svc-ring-1 { width:400px;height:400px;animation:svcSpin 24s linear infinite; }
.svc-ring-2 { width:580px;height:580px;animation:svcSpin 36s linear infinite reverse; border-color:rgba(0,84,223,0.08); }
.svc-ring-3 { width:760px;height:760px;animation:svcSpin 52s linear infinite; border-color:rgba(249,107,43,0.05); }
@keyframes svcSpin { to { transform:translate(-50%,-50%) rotate(360deg); } }

.svc-care-card {
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:24px;padding:2rem 1.75rem;
  position:relative;overflow:hidden;
  transition:transform 0.28s;
}
.svc-care-card:hover { transform:translateY(-4px); }
.svc-care-featured {
  border-color:#F96B2B;
  box-shadow:0 0 60px rgba(249,107,43,0.12),inset 0 1px 0 rgba(249,107,43,0.1);
}
.svc-care-glow {
  position:absolute;top:-30px;right:-30px;
  width:140px;height:140px;border-radius:50%;
  background:radial-gradient(circle,rgba(249,107,43,0.22) 0%,transparent 70%);
  filter:blur(20px);pointer-events:none;
}
.svc-care-name {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.1rem;
  color:#fff;margin:0 0 0.75rem;
  text-transform:uppercase;letter-spacing:0.04em;
}
.svc-care-price-row { display:flex;align-items:baseline;gap:0.15rem;margin-bottom:1.5rem; }
.svc-care-price {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:2.6rem;line-height:1;color:#fff;
}
.svc-care-mo {
  font:600 1rem/1 'Inter Tight',sans-serif;
  color:rgba(255,255,255,0.38);
}
.svc-care-list { list-style:none;padding:0;margin:0 0 1.75rem;display:flex;flex-direction:column;gap:0.7rem; }
.svc-care-item {
  display:flex;align-items:flex-start;gap:0.55rem;
  font:500 0.85rem/1.45 'Inter Tight',sans-serif;
  color:rgba(255,255,255,0.6);
}
.svc-care-item svg { flex-shrink:0;margin-top:2px; }
.svc-care-cta {
  display:block;text-align:center;
  border-radius:999px;padding:0.85rem;
  font:700 0.85rem/1 'Inter Tight',sans-serif;
  text-decoration:none;
  transition:opacity 0.2s,transform 0.2s;
}
.svc-care-cta:hover { opacity:0.88;transform:translateY(-1px); }
.svc-care-cta-ghost {
  border:1px solid rgba(255,255,255,0.18);
  color:rgba(255,255,255,0.72);
  background:rgba(255,255,255,0.04);
}
.svc-care-cta-orange { background:#F96B2B;color:#fff;box-shadow:0 10px 28px rgba(249,107,43,0.3); }
@media (max-width:639px) {
  .svc-care-grid { grid-template-columns:1fr !important; }
}

/* ─────────────── BUNDLE CARDS ─────────────── */
.svc-bundle-card {
  background:#fff;border-radius:22px;padding:2rem 1.75rem;
  border:1px solid #E5E7EB;
  transition:transform 0.28s,box-shadow 0.28s;
  box-shadow:0 2px 16px rgba(10,22,40,0.05);
  position:relative;overflow:hidden;
}
.svc-bundle-card:hover { transform:translateY(-5px);box-shadow:0 20px 48px rgba(10,22,40,0.1); }
.svc-bundle-featured { border:2px solid #F96B2B; }
.svc-bundle-top-accent {
  position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,#F96B2B,#ff9a6c);
}
.svc-bundle-dark {
  background:#0A1628;
  border-color:rgba(255,255,255,0.08);
}
.svc-bundle-dark-glow {
  position:absolute;bottom:-20px;right:-20px;
  width:180px;height:180px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,84,223,0.25) 0%,transparent 70%);
  filter:blur(24px);pointer-events:none;
}
.svc-bundle-name {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.2rem;color:#0A1628;margin:0 0 0.5rem;
}
.svc-bundle-includes {
  font:500 0.85rem/1.5 'Inter Tight',sans-serif;
  color:#9CA3AF;margin:0 0 1.5rem;
}
.svc-bundle-price-row { display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem; }
.svc-bundle-price {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:2.2rem;line-height:1;color:#0A1628;
}
.svc-bundle-save {
  font:700 0.62rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.08em;text-transform:uppercase;
  background:#dcfce7;color:#166534;
  padding:0.3rem 0.65rem;border-radius:999px;
}
.svc-bundle-link {
  font:700 0.85rem/1 'Inter Tight',sans-serif;
  text-decoration:none;
  transition:opacity 0.2s;
}
.svc-bundle-link:hover { opacity:0.7; }
@media (max-width:767px) {
  .svc-bundle-grid { grid-template-columns:1fr !important; }
}

/* ─────────────── PREMIUM CARDS ─────────────── */
.svc-premium-card {
  background:#F8F6F2;
  border-radius:20px;
  padding:1.75rem;
  border:1px solid rgba(10,22,40,0.07);
  display:flex;align-items:flex-start;gap:1rem;
  transition:transform 0.24s,box-shadow 0.24s,background 0.24s;
  cursor:default;
}
.svc-premium-card:hover {
  transform:translateY(-4px) translateX(4px);
  box-shadow:0 16px 40px rgba(10,22,40,0.1);
  background:#fff;
}
.svc-premium-inner { flex:1; }
.svc-premium-name {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:1.15rem;color:#0A1628;margin:0 0 0.35rem;
}
.svc-premium-price {
  font:700 0.95rem/1 'Inter Tight',sans-serif;
  color:#F96B2B;margin:0 0 0.65rem;
}
.svc-premium-desc {
  font:500 0.83rem/1.55 'Inter Tight',sans-serif;
  color:#6B7280;margin:0;
}
.svc-premium-arrow {
  color:#9CA3AF;flex-shrink:0;margin-top:4px;
  transition:transform 0.2s,color 0.2s;
}
.svc-premium-card:hover .svc-premium-arrow {
  transform:translate(4px,-2px);
  color:#0054DF;
}
@media (max-width:639px) {
  .svc-premium-grid { grid-template-columns:1fr !important; }
}

/* ─────────────── FAQ ─────────────── */
.svc-faq-list { display:flex;flex-direction:column; }
.svc-faq-item {
  border-bottom:1px solid rgba(10,22,40,0.08);
  transition:background 0.2s;
  border-radius:0;
}
.svc-faq-item.svc-faq-open { background:rgba(0,84,223,0.03);border-radius:12px; }
.svc-faq-q {
  width:100%;display:flex;align-items:center;justify-content:space-between;
  gap:1rem;
  background:none;border:none;cursor:pointer;
  padding:1.25rem 0.5rem;
  text-align:left;
  font:700 1rem/1.4 'Inter Tight',sans-serif;
  color:#0A1628;
}
.svc-faq-chevron {
  width:18px;height:18px;
  flex-shrink:0;color:#9CA3AF;
  transition:transform 0.3s cubic-bezier(.4,0,.2,1);
}
.svc-faq-body {
  max-height:0;overflow:hidden;
  transition:max-height 0.35s cubic-bezier(.4,0,.2,1);
}
.svc-faq-a {
  padding:0 0.5rem 1.25rem;
  font:500 0.92rem/1.65 'Inter Tight',sans-serif;
  color:#6B7280;margin:0;
}

/* ─────────────── CTA ─────────────── */
.svc-cta-grid {
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.04) 1px,transparent 1px);
  background-size:44px 44px;
  opacity:0.5;
}
.svc-cta-headline {
  font-family:'Oswald',sans-serif;
  font-weight:700;font-size:clamp(2.2rem,5vw,4rem);
  line-height:0.96;color:#fff;
  margin:0 0 0.5rem;
}
.svc-cta-btns {
  display:flex;flex-wrap:wrap;gap:1rem;
  justify-content:center;margin-top:2.5rem;
}
.svc-cta-primary {
  display:inline-flex;align-items:center;
  border-radius:999px;background:#F96B2B;
  padding:1rem 2rem;
  font:700 0.92rem/1 'Inter Tight',sans-serif;
  color:#fff;text-decoration:none;
  box-shadow:0 20px 40px rgba(249,107,43,0.32);
  transition:opacity 0.2s,transform 0.2s;
}
.svc-cta-primary:hover { opacity:0.9;transform:translateY(-2px); }
.svc-cta-ghost {
  display:inline-flex;align-items:center;
  border-radius:999px;
  border:1px solid rgba(255,255,255,0.22);
  padding:1rem 2rem;
  font:700 0.92rem/1 'Inter Tight',sans-serif;
  color:rgba(255,255,255,0.78);text-decoration:none;
  transition:border-color 0.2s,color 0.2s;
}
.svc-cta-ghost:hover { border-color:rgba(255,255,255,0.5);color:#fff; }

/* ═══════════════════════════════════════════
   FLOATING BUTTON
═══════════════════════════════════════════ */
#byo-float-btn {
  position:fixed;
  bottom:1.5rem;right:1.5rem;
  z-index:50;
  display:inline-flex;align-items:center;gap:0.5rem;
  background:#0A1628;color:#fff;
  border:none;cursor:pointer;
  font:700 0.82rem/1 'Inter Tight',sans-serif;
  padding:0.85rem 1.35rem;
  border-radius:999px;
  box-shadow:0 8px 32px rgba(10,22,40,0.28),0 2px 8px rgba(10,22,40,0.18);
  transition:background 0.25s,transform 0.25s,opacity 0.25s;
  opacity:1;
}
#byo-float-btn:hover { background:#F96B2B;transform:translateY(-2px);box-shadow:0 16px 40px rgba(249,107,43,0.32); }
@media (max-width:639px) {
  #byo-float-btn { bottom:1rem;right:1rem;font-size:0.72rem;padding:0.65rem 1rem; }
}

/* ═══════════════════════════════════════════
   BUILD YOUR OWN SECTION
═══════════════════════════════════════════ */
.byo-section {
  background:#F8F6F2;
  padding:6rem 0 5rem;
}

/* Header */
.byo-eyebrow {
  display:block;
  font:700 0.6rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.2em;text-transform:uppercase;
  color:#0054DF;margin-bottom:1rem;
}
.byo-headline {
  font-family:'Oswald',sans-serif;font-weight:700;
  font-size:clamp(2rem,4.5vw,3.2rem);line-height:1;
  color:#0A1628;margin:0 0 1rem;
}
.byo-subhead {
  font:500 1rem/1.6 'Inter Tight',sans-serif;
  color:#9CA3AF;max-width:32rem;margin:0 auto;
}
.byo-header { margin-bottom:3.5rem; }

/* Step wrapper */
.byo-step {
  background:#fff;
  border-radius:24px;
  padding:2rem 1.75rem;
  border:1px solid rgba(10,22,40,0.07);
  box-shadow:0 2px 16px rgba(10,22,40,0.04);
  margin-bottom:1.25rem;
}
.byo-step-label {
  font:700 0.6rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.2em;text-transform:uppercase;
  color:#F96B2B;margin:0 0 0.4rem;
}
.byo-step-title {
  font-family:'Oswald',sans-serif;font-weight:700;
  font-size:1.3rem;color:#0A1628;margin:0 0 0.3rem;
}
.byo-step-sub {
  font:500 0.85rem/1 'Inter Tight',sans-serif;
  color:#9CA3AF;margin:0 0 1.5rem;
}

/* ── Base / care card grids ── */
.byo-base-grid,
.byo-care-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0.85rem;
  margin-top:1.25rem;
}
@media (max-width:639px) {
  .byo-base-grid,
  .byo-care-grid { grid-template-columns:1fr; }
}

.byo-base-card,
.byo-care-card {
  border-radius:16px;padding:1.25rem;
  border:2px solid #E5E7EB;
  background:#fff;cursor:pointer;
  transition:border-color 0.2s,background 0.2s,transform 0.18s;
  position:relative;
}
.byo-base-card:hover,
.byo-care-card:hover { transform:translateY(-2px); }

/* Radio indicator */
.byo-base-radio {
  width:18px;height:18px;border-radius:50%;
  border:2px solid #D1D5DB;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:0.85rem;
  transition:border-color 0.2s;
}
.byo-radio-inner {
  width:9px;height:9px;border-radius:50%;
  background:transparent;
  transition:background 0.2s;
}
.byo-selected .byo-base-radio { border-color:#F96B2B; }
.byo-selected .byo-radio-inner { background:#F96B2B; }
.byo-selected {
  border-color:#F96B2B;
  background:rgba(249,107,43,0.04);
}

.byo-base-price {
  font-family:'Oswald',sans-serif;font-weight:700;
  font-size:1.55rem;line-height:1;color:#0A1628;margin:0 0 0.3rem;
}
.byo-base-name {
  font:700 0.85rem/1 'Inter Tight',sans-serif;
  color:#0A1628;margin:0 0 0.3rem;
}
.byo-base-desc {
  font:500 0.78rem/1.4 'Inter Tight',sans-serif;
  color:#9CA3AF;margin:0;
}

/* ── Feature grid ── */
.byo-feat-grid {
  display:grid;
