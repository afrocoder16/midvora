<!-- ═══════════════ SCRIPTS ═══════════════ -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
/* ══════════ WebGL HERO — particle morph (desktop only) ══════════
   Three.js is injected at runtime only on desktop so phones never
   download or parse the ~600KB library. */
(function () {
  if (window.innerWidth < 1024) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  if (new URLSearchParams(window.location.search).has('staticPreview')) return;

  var canvas = document.getElementById('webgl-hero');
  var hero = document.getElementById('hero');
  if (!canvas || !hero) return;

  var COUNT = 6500;
  var scene, camera, renderer, points, group;
  var current, from, to, rnd;
  var morph = { p: 1 };
  var shapes = [];
  var shapeNames = [];
  var shapeIndex = 0;
  var mouseX = 0, mouseY = 0;
  var running = true;
  var clock;

  function makeDotTexture() {
    var c = document.createElement('canvas');
    c.width = c.height = 64;
    var x = c.getContext('2d');
    var g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
    g.addColorStop(0, 'rgba(255,255,255,1)');
    g.addColorStop(0.35, 'rgba(255,255,255,0.7)');
    g.addColorStop(1, 'rgba(255,255,255,0)');
    x.fillStyle = g;
    x.fillRect(0, 0, 64, 64);
    var t = new THREE.CanvasTexture(c);
    return t;
  }

  function sphereShape() {
    var arr = new Float32Array(COUNT * 3);
    var golden = Math.PI * (3 - Math.sqrt(5));
    for (var i = 0; i < COUNT; i++) {
      var y = 1 - (i / (COUNT - 1)) * 2;
      var r = Math.sqrt(1 - y * y);
      var th = golden * i;
      arr[i * 3]     = Math.cos(th) * r * 2.1;
      arr[i * 3 + 1] = y * 2.1;
      arr[i * 3 + 2] = Math.sin(th) * r * 2.1;
    }
    return arr;
  }

  function knotShape() {
    var arr = new Float32Array(COUNT * 3);
    var P = 2, Q = 3, R = 1.55, r = 0.45;
    for (var i = 0; i < COUNT; i++) {
      var t = (i / COUNT) * Math.PI * 2;
      var jitter = 0.09;
      var cx = Math.cos(P * t) * (R + r * Math.cos(Q * t));
      var cy = Math.sin(P * t) * (R + r * Math.cos(Q * t));
      var cz = r * Math.sin(Q * t) * 1.6;
      arr[i * 3]     = cx + (Math.random() - 0.5) * jitter;
      arr[i * 3 + 1] = cy + (Math.random() - 0.5) * jitter;
      arr[i * 3 + 2] = cz + (Math.random() - 0.5) * jitter;
    }
    return arr;
  }

  function waveShape() {
    var arr = new Float32Array(COUNT * 3);
    var cols = 110, rows = Math.ceil(COUNT / cols);
    for (var i = 0; i < COUNT; i++) {
      var cx = i % cols, cy = Math.floor(i / cols);
      var x = (cx / (cols - 1) - 0.5) * 7.2;
      var y = (cy / (rows - 1) - 0.5) * 4.2;
      var z = Math.sin(x * 1.6) * 0.45 + Math.cos(y * 2.2) * 0.35;
      arr[i * 3] = x; arr[i * 3 + 1] = y; arr[i * 3 + 2] = z;
    }
    return arr;
  }

  function textShape() {
    var W = 640, H = 140;
    var c = document.createElement('canvas');
    c.width = W; c.height = H;
    var x = c.getContext('2d');
    x.fillStyle = '#fff';
    x.font = '700 104px Oswald, Impact, sans-serif';
    x.textAlign = 'center';
    x.textBaseline = 'middle';
    x.fillText('MIDVORA', W / 2, H / 2 + 6);
    var d = x.getImageData(0, 0, W, H).data;
    var pts = [];
    for (var yy = 0; yy < H; yy += 2) {
      for (var xx = 0; xx < W; xx += 2) {
        if (d[(yy * W + xx) * 4 + 3] > 128) {
          pts.push([(xx - W / 2) / 68, -(yy - H / 2) / 68]);
        }
      }
    }
    var arr = new Float32Array(COUNT * 3);
    if (!pts.length) return sphereShape();
    for (var i = 0; i < COUNT; i++) {
      var p = pts[(Math.random() * pts.length) | 0];
      arr[i * 3]     = p[0] + (Math.random() - 0.5) * 0.03;
      arr[i * 3 + 1] = p[1] + (Math.random() - 0.5) * 0.03;
      arr[i * 3 + 2] = (Math.random() - 0.5) * 0.25;
    }
    return arr;
  }

  function smoothstep(t) { return t * t * (3 - 2 * t); }

  function init() {
    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(50, hero.offsetWidth / hero.offsetHeight, 0.1, 100);
    camera.position.z = 6.4;

    renderer = new THREE.WebGLRenderer({ canvas: canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.75));
    renderer.setSize(hero.offsetWidth, hero.offsetHeight);
    renderer.setClearColor(0x000000, 0);

    shapes = [sphereShape(), textShape(), knotShape(), waveShape()];
    shapeNames = ['sphere', 'text', 'knot', 'wave'];
    shapeIndex = 0;

    current = new Float32Array(shapes[0]);
    from = new Float32Array(shapes[0]);
    to = new Float32Array(shapes[0]);
    rnd = new Float32Array(COUNT);
    for (var i = 0; i < COUNT; i++) rnd[i] = Math.random();

    var colors = new Float32Array(COUNT * 3);
    for (var j = 0; j < COUNT; j++) {
      var k = Math.random();
      if (k < 0.15) {
        colors[j * 3] = 0.976; colors[j * 3 + 1] = 0.42; colors[j * 3 + 2] = 0.17;
      } else {
        var m = Math.random();
        colors[j * 3]     = 0.0  + (0.557 - 0.0) * m;
        colors[j * 3 + 1] = 0.33 + (0.718 - 0.33) * m;
        colors[j * 3 + 2] = 0.875 + (1.0 - 0.875) * m;
      }
    }

    var geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(current, 3));
    geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

    var mat = new THREE.PointsMaterial({
      size: 0.05,
      map: makeDotTexture(),
      vertexColors: true,
      transparent: true,
      opacity: 0.85,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true
    });

    points = new THREE.Points(geo, mat);
    group = new THREE.Group();
    group.add(points);
    group.position.y = 0.15;
    scene.add(group);

    clock = new THREE.Clock();

    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', function (e) {
      mouseX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseY = (e.clientY / window.innerHeight) * 2 - 1;
    });

    if ('IntersectionObserver' in window) {
      new IntersectionObserver(function (entries) {
        running = entries[0].isIntersecting;
      }, { threshold: 0 }).observe(hero);
    }

    scheduleMorph();
    render();
  }

  function onResize() {
    if (!renderer) return;
    camera.aspect = hero.offsetWidth / hero.offsetHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(hero.offsetWidth, hero.offsetHeight);
  }

  function scheduleMorph() {
    setTimeout(function () {
      var next = (shapeIndex + 1) % shapes.length;
      from.set(current);
      to.set(shapes[next]);
      shapeIndex = next;
      morph.p = 0;
      if (typeof gsap !== 'undefined') {
        gsap.to(morph, { p: 1, duration: 2.2, ease: 'power2.inOut' });
        if (shapeNames[shapeIndex] === 'text') {
          gsap.to(group.rotation, { x: 0, y: 0, duration: 1.6, ease: 'power2.inOut' });
        }
      } else {
        morph.p = 1;
      }
      scheduleMorph();
    }, 5200);
  }

  var autoRot = 0;
  function render() {
    requestAnimationFrame(render);
    if (!running || !renderer) return;

    var time = clock.getElapsedTime();
    var isText = shapeNames[shapeIndex] === 'text';

    for (var i = 0; i < COUNT; i++) {
      var e = morph.p * 1.35 - rnd[i] * 0.35;
      if (e < 0) e = 0; else if (e > 1) e = 1;
      e = smoothstep(e);
      var i3 = i * 3;
      var wob = Math.sin(time * 1.1 + i * 0.37) * 0.012;
      current[i3]     = from[i3]     + (to[i3]     - from[i3])     * e + wob;
      current[i3 + 1] = from[i3 + 1] + (to[i3 + 1] - from[i3 + 1]) * e + Math.cos(time * 0.9 + i * 0.53) * 0.012;
      current[i3 + 2] = from[i3 + 2] + (to[i3 + 2] - from[i3 + 2]) * e;
    }
    points.geometry.attributes.position.needsUpdate = true;

    if (!isText) {
      autoRot += 0.0016;
      group.rotation.y += ((autoRot + mouseX * 0.35) - group.rotation.y) * 0.045;
      group.rotation.x += ((mouseY * 0.18) - group.rotation.x) * 0.045;
    } else {
      group.position.x += ((mouseX * 0.25) - group.position.x) * 0.04;
      group.position.y += ((0.15 - mouseY * 0.15) - group.position.y) * 0.04;
    }

    renderer.render(scene, camera);
  }

  var lib = document.createElement('script');
  lib.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
  lib.async = true;
  lib.onload = function () {
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(init);
    } else {
      init();
    }
  };
  document.head.appendChild(lib);
})();
</script>

<script is:inline>
/* ══════════ Page interactions ══════════ */
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var staticPreview = new URLSearchParams(window.location.search).has('staticPreview');
  var finePointer = window.matchMedia('(pointer: fine)').matches;

  function setCountersFinal() {
    document.querySelectorAll('.stat-counter').forEach(function (el) {
      var target = parseInt(el.dataset.target || '0', 10);
      el.textContent = target + (el.dataset.suffix || '');
    });
  }

  /* ── scroll progress (cheap, always on) ── */
  (function () {
    var bar = document.getElementById('scroll-progress');
    if (!bar) return;
    var ticking = false;
    function update() {
      var doc = document.documentElement;
      var max = doc.scrollHeight - window.innerHeight;
      var p = max > 0 ? window.scrollY / max : 0;
      bar.style.transform = 'scaleX(' + p + ')';
      ticking = false;
    }
    window.addEventListener('scroll', function () {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }, { passive: true });
    update();
  })();

  /* ── before/after slider (works even with reduced motion) ── */
  (function () {
    var wrap = document.getElementById('ba');
    var range = document.getElementById('ba-range');
    if (!wrap || !range) return;
    range.addEventListener('input', function () {
      wrap.style.setProperty('--cut', range.value + '%');
    });
  })();

  /* ── pause marquees while offscreen (mobile GPU relief) ── */
  (function () {
    var mz = document.querySelector('.v2-marquee-zone');
    if (!mz || !('IntersectionObserver' in window)) return;
    var tracks = mz.querySelectorAll('.mq-track');
    new IntersectionObserver(function (entries) {
      var run = entries[0].isIntersecting;
      tracks.forEach(function (t) { t.style.animationPlayState = run ? 'running' : 'paused'; });
    }).observe(mz);
  })();

  if (reduced || staticPreview) {
    setCountersFinal();
    return;
  }

  /* ── split hero headline into chars ── */
  document.querySelectorAll('[data-split]').forEach(function (line) {
    var text = line.textContent;
    var isGradient = line.classList.contains('v2-h1-orange');
    var fromC = [249, 107, 43], toC = [255, 192, 122];
    line.setAttribute('aria-label', text);
    line.textContent = '';
    line.classList.add('is-split');
    text.split('').forEach(function (ch, i) {
      var s = document.createElement('span');
      s.className = 'ch';
      s.setAttribute('aria-hidden', 'true');
      s.textContent = ch === ' ' ? ' ' : ch;
      if (isGradient) {
        var t = text.length > 1 ? i / (text.length - 1) : 0;
        s.style.color = 'rgb(' +
          Math.round(fromC[0] + (toC[0] - fromC[0]) * t) + ',' +
          Math.round(fromC[1] + (toC[1] - fromC[1]) * t) + ',' +
          Math.round(fromC[2] + (toC[2] - fromC[2]) * t) + ')';
      }
      line.appendChild(s);
    });
  });

  /* ── hero intro timeline ── */
  var intro = gsap.timeline({ defaults: { ease: 'power3.out' } });
  intro
    .fromTo('.hero-eyebrow', { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.55, stagger: 0.08 })
    .fromTo('.v2-h1 .ch',
      { yPercent: 110, rotateX: -55, opacity: 0 },
      { yPercent: 0, rotateX: 0, opacity: 1, duration: 0.85, stagger: 0.022, ease: 'power4.out' }, '-=0.2')
    .fromTo('.v2-rotator-row', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.55 }, '-=0.45')
    .fromTo('.v2-sub',        { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.4')
    .fromTo('.hero-ctas',     { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.55 }, '-=0.4')
    .fromTo('.hero-proof-strip', { opacity: 0, y: 14 }, { opacity: 1, y: 0, duration: 0.5 }, '-=0.35')
    .fromTo('.hero-cue',      { opacity: 0 }, { opacity: 1, duration: 0.8 }, '-=0.2');

  /* ── rotating industry word ──
     One reused element (append/remove pattern leaked words on slow phones
     when tweens got throttled and onComplete never fired). */
  (function () {
    var box = document.getElementById('word-rotator');
    if (!box) return;
    var word = box.querySelector('.v2-word');
    if (!word) return;
    var words  = ['restaurants', 'salons', 'contractors', 'gyms', 'boutiques', 'auto shops'];
    var colors = ['#F96B2B', '#4D9FFF', '#22D3EE', '#34D399', '#FFC53D', '#F472B6'];
    var idx = 0;
    word.style.color = colors[0];
    setInterval(function () {
      if (document.hidden) return;
      idx = (idx + 1) % words.length;
      gsap.timeline()
        .to(word, { yPercent: -110, opacity: 0, duration: 0.32, ease: 'power2.in', overwrite: 'auto' })
        .add(function () {
          word.textContent = words[idx];
          word.style.color = colors[idx];
          box.style.borderBottomColor = colors[idx] + '66';
        })
        .fromTo(word,
          { yPercent: 110, opacity: 0 },
          { yPercent: 0, opacity: 1, duration: 0.4, ease: 'power2.out' });
    }, 2600);
  })();

  /* ── generic reveals ── */
  document.querySelectorAll('[data-reveal]').forEach(function (el) {
    gsap.fromTo(el,
      { opacity: 0, y: 36 },
      {
        opacity: 1, y: 0, duration: 0.85, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 86%' }
      });
  });

  /* ── stats counters + bar draw ── */
  var statsDone = false;
  ScrollTrigger.create({
    trigger: '#stats-section',
    start: 'top 78%',
    once: true,
    onEnter: function () {
      if (statsDone) return;
      statsDone = true;
      document.querySelectorAll('.stat-counter').forEach(function (el) {
        var obj = { val: 0 };
        gsap.to(obj, {
          val: parseInt(el.dataset.target || '0', 10),
          duration: 1.9,
          ease: 'power2.out',
          onUpdate: function () {
            el.textContent = Math.round(obj.val) + (el.dataset.suffix || '');
          }
        });
      });
      gsap.fromTo('.v2-stat-bar', { scaleX: 0 }, { scaleX: 1, duration: 1.1, ease: 'power3.out', stagger: 0.12 });
    }
  });

  /* ── marquee velocity skew ── */
  (function () {
    var proxy = { skew: 0 };
    var setter = gsap.quickSetter('.mq-track', 'skewX', 'deg');
    var clampFn = gsap.utils.clamp(-9, 9);
    ScrollTrigger.create({
      onUpdate: function (self) {
        var s = clampFn(self.getVelocity() / -260);
        if (Math.abs(s) > Math.abs(proxy.skew)) {
          proxy.skew = s;
          gsap.to(proxy, {
            skew: 0, duration: 0.75, ease: 'power3',
            overwrite: true,
            onUpdate: function () { setter(proxy.skew); }
          });
        }
      }
    });
  })();

  /* ── before/after intro wiggle ── */
  (function () {
    var wrap = document.getElementById('ba');
    var range = document.getElementById('ba-range');
    if (!wrap || !range) return;
    ScrollTrigger.create({
      trigger: wrap,
      start: 'top 70%',
      once: true,
      onEnter: function () {
        var o = { v: 50 };
        gsap.timeline()
          .to(o, {
            v: 74, duration: 0.9, ease: 'power2.inOut',
            onUpdate: function () { wrap.style.setProperty('--cut', o.v + '%'); range.value = o.v; }
          })
          .to(o, {
            v: 32, duration: 1.0, ease: 'power2.inOut',
            onUpdate: function () { wrap.style.setProperty('--cut', o.v + '%'); range.value = o.v; }
          })
          .to(o, {
            v: 50, duration: 0.8, ease: 'power2.inOut',
            onUpdate: function () { wrap.style.setProperty('--cut', o.v + '%'); range.value = o.v; }
          });
      }
    });
  })();

  /* ── horizontal HOW section (desktop pin) ── */
  gsap.matchMedia().add('(min-width: 1024px)', function () {
    var track = document.getElementById('how-track');
    var fill = document.getElementById('how-progress-fill');
    if (!track) return;
    gsap.to(track, {
      xPercent: -66.6666,
      ease: 'none',
      scrollTrigger: {
        trigger: '#how',
        pin: true,
        scrub: 1,
        start: 'top top',
        end: '+=220%',
        onUpdate: function (self) {
          if (fill) fill.style.transform = 'scaleX(' + self.progress + ')';
        }
      }
    });
    gsap.utils.toArray('.v2-panel-card').forEach(function (card) {
      gsap.fromTo(card, { y: 40, opacity: 0.4 }, {
        y: 0, opacity: 1, duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: '#how', start: 'top 60%' }
      });
    });
  });

  /* ── 3D tilt cards ── */
  if (finePointer) {
    document.querySelectorAll('[data-tilt]').forEach(function (card) {
      var rx = gsap.quickTo(card, 'rotationX', { duration: 0.45, ease: 'power2.out' });
      var ry = gsap.quickTo(card, 'rotationY', { duration: 0.45, ease: 'power2.out' });
      gsap.set(card, { transformPerspective: 700 });
      card.addEventListener('pointermove', function (e) {
        var r = card.getBoundingClientRect();
        var px = (e.clientX - r.left) / r.width;
        var py = (e.clientY - r.top) / r.height;
        rx((0.5 - py) * 10);
        ry((px - 0.5) * 12);
        card.style.setProperty('--gx', (px * 100) + '%');
        card.style.setProperty('--gy', (py * 100) + '%');
      });
      card.addEventListener('pointerleave', function () {
        rx(0); ry(0);
      });
    });
  }

  /* ── industries cursor spotlight ── */
  if (finePointer) {
    var ind = document.getElementById('industries');
    if (ind) {
      var spot = ind.querySelector('.v2-spotlight');
      ind.addEventListener('pointermove', function (e) {
        var r = ind.getBoundingClientRect();
        spot.style.setProperty('--sx', (e.clientX - r.left) + 'px');
        spot.style.setProperty('--sy', (e.clientY - r.top) + 'px');
      });
    }
  }

  /* ── CTA headline ── */
  gsap.fromTo('.cta-headline',
    { opacity: 0, y: 50 },
    {
      opacity: 1, y: 0, duration: 1, ease: 'power3.out',
      scrollTrigger: { trigger: '#cta-banner', start: 'top 78%' }
    });
  gsap.fromTo('#sample-form',
    { opacity: 0, y: 30 },
    {
      opacity: 1, y: 0, duration: 0.8, ease: 'power2.out', delay: 0.15,
      scrollTrigger: { trigger: '#cta-banner', start: 'top 72%' }
    });

  /* ── custom cursor + magnetic buttons ── */
  if (finePointer) {
    var docEl = document.documentElement;
    docEl.classList.add('fx-cursor');
    var dot = document.getElementById('cur-dot');
    var ring = document.getElementById('cur-ring');
    var mx = -100, my = -100, ringX = -100, ringY = -100;

    window.addEventListener('mousemove', function (e) {
      mx = e.clientX; my = e.clientY;
      dot.style.transform = 'translate(' + (mx - 3.5) + 'px,' + (my - 3.5) + 'px)';
    }, { passive: true });

    (function loopCursor() {
      ringX += (mx - ringX) * 0.16;
      ringY += (my - ringY) * 0.16;
      ring.style.transform = 'translate(' + (ringX - ring.offsetWidth / 2) + 'px,' + (ringY - ring.offsetHeight / 2) + 'px)';
      requestAnimationFrame(loopCursor);
    })();

    document.addEventListener('mouseover', function (e) {
      if (e.target.closest('a, button, input, [data-tilt], .ba-range, label')) {
        ring.classList.add('is-hover');
      }
    });
    document.addEventListener('mouseout', function (e) {
      if (e.target.closest('a, button, input, [data-tilt], .ba-range, label')) {
        ring.classList.remove('is-hover');
      }
    });
    document.addEventListener('mousedown', function () { ring.classList.add('is-down'); });
    document.addEventListener('mouseup', function () { ring.classList.remove('is-down'); });

    /* magnetic pull */
    document.querySelectorAll('[data-magnetic]').forEach(function (btn) {
      var qx = gsap.quickTo(btn, 'x', { duration: 0.35, ease: 'power3.out' });
      var qy = gsap.quickTo(btn, 'y', { duration: 0.35, ease: 'power3.out' });
      btn.addEventListener('pointermove', function (e) {
        var r = btn.getBoundingClientRect();
        qx((e.clientX - (r.left + r.width / 2)) * 0.28);
        qy((e.clientY - (r.top + r.height / 2)) * 0.28);
      });
      btn.addEventListener('pointerleave', function () {
        gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
      });
    });
  }
})();

/* ══════════ scrollTo param + form submit (unchanged wiring) ══════════ */
(function () {
  var scrollTarget = new URLSearchParams(window.location.search).get('scrollTo');
  if (scrollTarget) {
    var scrollToRequestedSection = function () {
      var target = document.getElementById(scrollTarget);
      if (!target) return;
      window.setTimeout(function () {
        target.scrollIntoView({ block: 'start' });
      }, 80);
    };
    if (document.readyState === 'complete') {
      scrollToRequestedSection();
    } else {
      window.addEventListener('load', scrollToRequestedSection, { once: true });
    }
  }

  var form = document.getElementById('sample-form');
  if (!form) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    var data = {};
    new FormData(form).forEach(function (v, k) { data[k] = v; });

    btn.textContent = 'Sending...';
    btn.disabled = true;

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        access_key: 'e7f6edce-9410-45b7-a058-a03f661f953b',
        subject: 'New Free Sample Request — Midvora (Homepage)',
        from_name: data.businessName,
        businessName: data.businessName,
        businessType: data.businessType,
        city: data.city,
        contact: data.contact,
      }),
    })
      .then(function (res) { return res.json(); })
      .then(function (json) {
        if (json.success) {
          btn.textContent = 'Request received. We\'ll be in touch soon!';
          btn.style.background = '#22c55e';
          form.reset();
          setTimeout(function () {
            btn.textContent = 'Build My Free Sample →';
            btn.disabled = false;
            btn.style.background = '#F96B2B';
          }, 5000);
        } else {
          throw new Error('fail');
        }
      })
      .catch(function () {
        btn.textContent = 'Something went wrong. Call (507) 530-4837';
        btn.style.background = '#EF4444';
        setTimeout(function () {
          btn.textContent = 'Build My Free Sample →';
          btn.disabled = false;
          btn.style.background = '#F96B2B';
        }, 5000);
      });
  });
})();
</script>

