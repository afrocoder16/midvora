        var isize=n.small?'15':'18';
        var iconSvg=n.icon?('<path d="'+n.icon+'"/>'):'<circle cx="12" cy="12" r="4"/>';
        el.innerHTML='<div style="display:flex;align-items:center;gap:9px;padding:'+pad+';border-radius:16px;background:rgba(10,20,50,0.92);border:1px solid rgba('+rgb+',0.45);box-shadow:0 4px 24px rgba(0,0,0,0.6),0 0 12px rgba('+rgb+',0.12),inset 0 1px 0 rgba(255,255,255,0.08);backdrop-filter:blur(12px);white-space:nowrap;"><div style=\'width:32px;height:32px;border-radius:10px;background:rgba('+rgb+',0.18);border:1px solid rgba('+rgb+',0.35);display:flex;align-items:center;justify-content:center;flex-shrink:0;\'><svg width="'+isize+'" height="'+isize+'" viewBox="0 0 24 24" fill="none" stroke="'+n.color+'" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">'+iconSvg+'</svg></div><span style=\'font-family:"Inter Tight",sans-serif;font-weight:700;color:#fff;font-size:'+fsize+';\'>'+n.label+'</span></div>';
      }
      nodesEl.appendChild(el);
      cardEls[n.id]=el;
    });

    /* ── main loop ── */
    function draw(){
      var W=canvas.width/(window.devicePixelRatio||1);
      var H=canvas.height/(window.devicePixelRatio||1);

      ctx.clearRect(0,0,W,H);

      /* draw edges */
      EDGES.forEach(function(e,i){
        var na=NODES.find(function(n){return n.id===e[0];});
        var nb=NODES.find(function(n){return n.id===e[1];});
        if(!na||!nb)return;
        var isHub=e[0]==='hub'||e[1]==='hub';
        var ax=na.sx, ay=na.sy, bx=nb.sx, by=nb.sy;

        /* lines are invisible — only pulse dots travel */

        /* traveling pulse dot */
        var p=pulses[i];
        p.t+=p.speed;
        if(p.t>1)p.t=0;
        var dotX=ax+(bx-ax)*p.t;
        var dotY=ay+(by-ay)*p.t;
        var pcolor=isHub?'rgba(80,160,255,':'rgba(249,130,60,';
        var gr=ctx.createRadialGradient(dotX,dotY,0,dotX,dotY,10);
        gr.addColorStop(0,pcolor+'1)');
        gr.addColorStop(0.4,pcolor+'0.4)');
        gr.addColorStop(1,'rgba(0,0,0,0)');
        ctx.beginPath();
        ctx.arc(dotX,dotY,10,0,Math.PI*2);
        ctx.fillStyle=gr;
        ctx.fill();
        ctx.beginPath();
        ctx.arc(dotX,dotY,3,0,Math.PI*2);
        ctx.fillStyle=isHub?'rgba(180,220,255,1)':'rgba(255,190,130,1)';
        ctx.fill();
      });

      /* draw node halos */
      NODES.forEach(function(n){
        if(n.hub){
          var hg=ctx.createRadialGradient(n.sx,n.sy,0,n.sx,n.sy,80);
          hg.addColorStop(0,'rgba(0,84,223,0.22)');
          hg.addColorStop(1,'rgba(0,84,223,0)');
          ctx.beginPath();
          ctx.arc(n.sx,n.sy,80,0,Math.PI*2);
          ctx.fillStyle=hg;
          ctx.fill();
        } else {
          var rgb=n.color==='#F96B2B'?'249,107,43':'142,183,255';
          var ng=ctx.createRadialGradient(n.sx,n.sy,0,n.sx,n.sy,28);
          ng.addColorStop(0,'rgba('+rgb+',0.16)');
          ng.addColorStop(1,'rgba('+rgb+',0)');
          ctx.beginPath();
          ctx.arc(n.sx,n.sy,28,0,Math.PI*2);
          ctx.fillStyle=ng;
          ctx.fill();
        }
      });

      /* position HTML cards — centered on their coords */
      NODES.forEach(function(n){
        var el=cardEls[n.id];
        if(!el)return;
        el.style.left=n.sx+'px';
        el.style.top=n.sy+'px';
        el.style.transform='translate(-50%,-50%)';
        el.style.opacity='1';
        el.style.zIndex=n.hub?'50':'10';
      });

      requestAnimationFrame(draw);
    }

    draw();
  })();
  </script>
</section>

