  color: #28CA41;
}
.ba-live i { width: 6px; height: 6px; border-radius: 50%; background: #28CA41; box-shadow: 0 0 8px 2px rgba(40,202,65,0.6); }
.ba-new-body { flex: 1; padding: clamp(0.8rem, 2.5vw, 1.4rem); display: flex; flex-direction: column; gap: clamp(0.6rem, 1.8vw, 1rem); }
.ba-new-hero {
  border-radius: 18px;
  background: linear-gradient(135deg, #0054DF 0%, #08224D 100%);
  padding: clamp(0.9rem, 3vw, 1.6rem);
}
.ba-new-eyebrow {
  margin: 0 0 0.4rem;
  font: 700 0.58rem/1 'Inter Tight', sans-serif;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.55);
}
.ba-new-title {
  margin: 0 0 0.75rem;
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(1.5rem, 4.5vw, 2.5rem); line-height: 0.96; color: #fff;
}
.ba-new-pills { display: flex; gap: 0.45rem; flex-wrap: wrap; }
.ba-pill-solid, .ba-pill-ghost {
  border-radius: 999px; padding: 0.5rem 0.9rem;
  font: 700 0.6rem/1 'Inter Tight', sans-serif;
  text-transform: uppercase; letter-spacing: 0.08em;
}
.ba-pill-solid { background: #F96B2B; color: #fff; }
.ba-pill-ghost { background: rgba(255,255,255,0.14); color: rgba(255,255,255,0.8); }
.ba-new-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.ba-new-chip {
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05);
  padding: 0.45rem 0.8rem;
  font: 600 0.62rem/1 'Inter Tight', sans-serif; color: rgba(255,255,255,0.65);
}
.ba-new-lines { display: flex; flex-direction: column; gap: 0.45rem; }
.ba-new-lines div { height: 0.4rem; border-radius: 999px; background: rgba(255,255,255,0.1); }

/* BEFORE layer */
.ba-old {
  position: absolute; inset: 0; z-index: 2;
  background: #fdfdf6;
  clip-path: inset(0 calc(100% - var(--cut, 50%)) 0 0);
  will-change: clip-path;
  display: flex; flex-direction: column;
}
.ba-old-bar {
  padding: 0.7rem 1rem;
  background: #d4d0c8; border-bottom: 2px solid #808080;
  font: 600 0.68rem/1 'Courier New', monospace; color: #333;
  white-space: nowrap; overflow: hidden;
}
.ba-old-body {
  flex: 1; padding: clamp(0.8rem, 2.5vw, 1.5rem);
  font-family: 'Times New Roman', Times, serif; color: #000;
  display: flex; flex-direction: column; gap: clamp(0.4rem, 1.5vw, 0.75rem);
  overflow: hidden;
}
.ba-old-title {
  margin: 0;
  font-size: clamp(1rem, 3.4vw, 1.7rem); font-weight: 700;
  color: #cc0000; text-decoration: underline; text-align: center;
}
.ba-old-nav { margin: 0; text-align: center; font-size: clamp(0.68rem, 2vw, 0.9rem); color: #0000EE; }
.ba-old-nav u { margin-inline: 0.1rem; }
.ba-old-blink {
  margin: 0; text-align: center;
  font-size: clamp(0.66rem, 2vw, 0.9rem); font-weight: 700; color: #008000;
  animation: baBlink 1s steps(2, start) infinite;
}
@keyframes baBlink { to { visibility: hidden; } }
.ba-old-table {
  border: 2px solid #808080; background: #ffffcc;
  padding: 0.6rem 0.8rem; font-size: clamp(0.66rem, 1.9vw, 0.88rem);
}
.ba-old-table p { margin: 0.2rem 0; }
.ba-old-hl { background: #ffff00; font-weight: 700; color: #0000EE; text-decoration: underline; }
.ba-old-construction {
  align-self: center;
  background: repeating-linear-gradient(45deg, #f7c948 0 12px, #111 12px 24px);
  color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,0.9);
  font: 700 clamp(0.6rem, 1.8vw, 0.8rem)/1 Arial, sans-serif;
  letter-spacing: 0.1em;
  padding: 0.5rem 1rem; border: 2px solid #111;
}
.ba-old-counter { margin: 0; text-align: center; font: 700 clamp(0.62rem, 1.8vw, 0.82rem)/1 'Courier New', monospace; background: #000; color: #00ff00; padding: 0.35rem; align-self: center; }
.ba-old-fine { margin: 0; text-align: center; font-size: clamp(0.56rem, 1.6vw, 0.72rem); color: #666; font-style: italic; }

/* tags, line, handle, range */
.ba-tag {
  position: absolute; bottom: 0.9rem; z-index: 3;
  border-radius: 999px; padding: 0.45rem 0.9rem;
  font: 700 0.58rem/1 'Inter Tight', sans-serif;
  text-transform: uppercase; letter-spacing: 0.14em;
}
.ba-tag-old { left: 0.9rem; background: rgba(0,0,0,0.75); color: #ffd7c2; }
.ba-tag-new { right: 0.9rem; background: rgba(249,107,43,0.9); color: #fff; }
.ba-line {
  position: absolute; top: 0; bottom: 0; z-index: 4;
  left: var(--cut, 50%); width: 2px; margin-left: -1px;
  background: linear-gradient(180deg, rgba(249,107,43,0.2), #F96B2B 50%, rgba(249,107,43,0.2));
  box-shadow: 0 0 18px rgba(249,107,43,0.55);
  pointer-events: none;
}
.ba-handle {
  position: absolute; top: 50%; z-index: 5;
  left: var(--cut, 50%);
  width: 46px; height: 46px; margin: -23px 0 0 -23px;
  border-radius: 50%;
  background: #F96B2B; color: #fff;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 10px 30px rgba(249,107,43,0.55), 0 0 0 6px rgba(249,107,43,0.2);
  pointer-events: none;
}
.ba-range {
  position: absolute; inset: 0; z-index: 6;
  width: 100%; height: 100%;
  opacity: 0; margin: 0;
  cursor: ew-resize;
  -webkit-appearance: none; appearance: none;
  background: transparent;
}
.ba-range::-webkit-slider-thumb { -webkit-appearance: none; width: 60px; height: 100%; }
.ba-range::-moz-range-thumb { width: 60px; height: 9999px; border: 0; background: transparent; }
.ba-footnote {
  margin: 1.8rem auto 0; max-width: 34rem; text-align: center;
  font: 500 0.9rem/1.6 'Inter Tight', sans-serif; color: rgba(255,255,255,0.38);
}
.ba-footnote em { color: rgba(249,107,43,0.9); font-style: normal; font-weight: 700; }

/* ---------- HOW (horizontal) ---------- */
.v2-how { position: relative; background: #050e1c; overflow: hidden; }
.v2-how-header {
  text-align: center;
  padding: clamp(4rem, 7vw, 6.5rem) 1.25rem 1rem;
  position: relative; z-index: 2;
}
.v2-how-viewport { position: relative; overflow: hidden; }
.v2-how-track { display: flex; width: 300%; }
.v2-panel {
  width: 33.3333%; flex-shrink: 0;
  min-height: 78vh;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  padding: 3rem 1.5rem 5rem;
}
.v2-panel-num {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -54%);
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(14rem, 30vw, 26rem); line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1.5px rgba(142,183,255,0.24);
  pointer-events: none; user-select: none;
}
.v2-num-orange { -webkit-text-stroke-color: rgba(249,107,43,0.28); }
.v2-panel-card {
  position: relative; z-index: 2;
  width: min(100%, 26rem);
  border-radius: 26px;
  padding: 2.4rem 2.1rem 2rem;
  backdrop-filter: blur(14px);
}
.v2-panel-blue {
  background: linear-gradient(150deg, rgba(14,26,50,0.94), rgba(8,16,32,0.9));
  border: 1px solid rgba(0,84,223,0.28);
  box-shadow: 0 40px 90px rgba(0,0,0,0.5), 0 0 50px rgba(0,84,223,0.1);
}
.v2-panel-orange {
  background: linear-gradient(150deg, rgba(32,17,8,0.95), rgba(18,9,4,0.92));
  border: 1px solid rgba(249,107,43,0.35);
  box-shadow: 0 40px 90px rgba(0,0,0,0.55), 0 0 60px rgba(249,107,43,0.12);
}
.v2-panel-green {
  background: linear-gradient(150deg, rgba(8,28,16,0.95), rgba(5,16,10,0.92));
  border: 1px solid rgba(40,202,65,0.25);
  box-shadow: 0 40px 90px rgba(0,0,0,0.5), 0 0 50px rgba(40,202,65,0.08);
}
.v2-panel-flag {
  position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  white-space: nowrap;
  background: #F96B2B; color: #fff;
  border-radius: 999px; padding: 0.35rem 0.9rem;
  font: 700 0.56rem/1 'Inter Tight', sans-serif;
  letter-spacing: 0.14em; text-transform: uppercase;
  box-shadow: 0 8px 24px rgba(249,107,43,0.4);
}
.v2-panel-icon {
  width: 56px; height: 56px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(0,84,223,0.12); border: 1px solid rgba(0,84,223,0.3);
  margin-bottom: 1.3rem;
}
.v2-panel-icon-orange { background: rgba(249,107,43,0.12); border-color: rgba(249,107,43,0.3); }
.v2-panel-icon-green  { background: rgba(40,202,65,0.1); border-color: rgba(40,202,65,0.28); }
.v2-panel-card h3 {
  margin: 0 0 0.7rem;
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: 1.7rem; color: #fff;
}
.v2-panel-card p { margin: 0; font: 500 0.92rem/1.65 'Inter Tight', sans-serif; color: rgba(255,255,255,0.45); }
.v2-panel-foot {
  margin-top: 1.5rem; padding-top: 1rem;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex; align-items: center; gap: 0.55rem;
  font: 700 0.6rem/1 'Inter Tight', sans-serif;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}
.v2-panel-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.v2-how-progress {
  position: relative; z-index: 2;
  width: min(60%, 22rem); height: 3px; border-radius: 999px;
  background: rgba(255,255,255,0.08);
  margin: 0 auto; transform: translateY(-2.4rem);
}
#how-progress-fill {
  height: 100%; width: 100%; border-radius: inherit;
  background: linear-gradient(90deg, #0054DF, #F96B2B);
  transform: scaleX(0); transform-origin: 0 50%;
}

/* mobile: vertical stack */
@media (max-width: 1023px) {
  .v2-how-track { display: flex; flex-direction: column; width: 100%; gap: 0.5rem; }
  .v2-panel { width: 100%; min-height: 0; padding: 2.4rem 1.25rem; }
  .v2-panel-num {
    font-size: 9rem;
    top: 0; left: auto; right: 0;
    transform: translate(6%, -18%);
  }
  .v2-how-progress { display: none; }
  .v2-how { padding-bottom: 3.5rem; }
}

/* ---------- DELIVERABLES (tilt) ---------- */
.v2-deliver { background: #F8F6F2; padding-block: clamp(4.5rem, 8vw, 7.5rem); }
.v2-deliver-head { text-align: center; margin-bottom: clamp(2.4rem, 5vw, 3.8rem); }
.v2-tilt-grid {
  display: grid; gap: 1.1rem;
  grid-template-columns: 1fr;
}
@media (min-width: 640px)  { .v2-tilt-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
@media (min-width: 1024px) { .v2-tilt-grid { grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.4rem; } }
.v2-tcard {
  position: relative; overflow: hidden;
  border-radius: 22px;
  background: #ffffff;
  border: 1px solid rgba(10,22,40,0.08);
  box-shadow: 0 10px 34px rgba(10,22,40,0.07);
  padding: 1.9rem 1.7rem;
  transform-style: preserve-3d;
  will-change: transform;
}
.tilt-glare {
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(340px circle at var(--gx, 50%) var(--gy, 50%), rgba(0,84,223,0.1), transparent 65%);
  opacity: 0; transition: opacity 0.3s;
}
.v2-tcard:hover .tilt-glare { opacity: 1; }
.v2-tcard-icon {
  width: 50px; height: 50px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 1.15rem;
  color: var(--acc, #0054DF);
  background: var(--acc-bg, rgba(0,84,223,0.09));
}
.v2-ic-blue   { --acc: #0054DF; --acc-bg: rgba(0,84,223,0.09); }
.v2-ic-orange { --acc: #F96B2B; --acc-bg: rgba(249,107,43,0.1); }
.v2-tcard h3 {
  margin: 0 0 0.5rem;
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: 1.25rem; color: #0A1628;
}
.v2-tcard p { margin: 0; font: 500 0.88rem/1.6 'Inter Tight', sans-serif; color: #6B7280; }

/* ---------- PRICING ---------- */
.v2-pricing {
  position: relative; overflow: hidden;
  background: #0A1628;
  padding-block: clamp(4.5rem, 8vw, 7.5rem);
}
.v2-pricing::before {
  content: ''; position: absolute; top: -30%; right: -10%;
  width: 44rem; height: 44rem; border-radius: 50%;
  background: radial-gradient(circle, rgba(249,107,43,0.13) 0%, transparent 60%);
  filter: blur(50px); pointer-events: none;
}
.v2-pricing::after {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
  background-size: 32px 32px; pointer-events: none;
}
.v2-pricing-grid {
  position: relative; z-index: 2;
  display: grid; gap: 3rem; align-items: center;
  grid-template-columns: 1fr;
}
@media (min-width: 1024px) { .v2-pricing-grid { grid-template-columns: 1.1fr 1fr; } }
.v2-price-chips { margin-top: 1.8rem; display: flex; flex-wrap: wrap; gap: 0.6rem; }
.v2-chip {
  display: inline-flex; align-items: center; gap: 0.5rem;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05);
  padding: 0.6rem 1.05rem;
  font: 700 0.66rem/1 'Inter Tight', sans-serif;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(255,255,255,0.6);
}
.v2-chip::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
  background: var(--dot, #F96B2B);
  box-shadow: 0 0 8px var(--dot, #F96B2B);
}
.v2-pricing-figure { text-align: center; }
.v2-big-price {
  display: block;
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(6.5rem, 16vw, 13rem); line-height: 0.95;
  color: transparent;
  -webkit-text-stroke: 2px rgba(249,107,43,0.8);
  text-shadow: 0 0 80px rgba(249,107,43,0.25);
}
.v2-big-price-sub {
  display: block; margin-top: 0.8rem;
  font: 600 0.85rem/1.5 'Inter Tight', sans-serif;
  color: rgba(255,255,255,0.35);
}

/* ---------- INDUSTRIES ---------- */
.v2-industries {
  position: relative; overflow: hidden;
  background: #06101f;
  padding-block: clamp(4.5rem, 8vw, 7.5rem);
}
.v2-spotlight {
  position: absolute; inset: 0; pointer-events: none; z-index: 1;
  background: radial-gradient(560px circle at var(--sx, 50%) var(--sy, 30%), rgba(0,84,223,0.16), transparent 65%);
}
.v2-industries .v2-shell { position: relative; z-index: 2; }
.v2-ind-head { text-align: center; margin-bottom: clamp(2.2rem, 4.5vw, 3.5rem); }
.v2-ind-grid {
  display: grid; gap: 0.9rem;
  grid-template-columns: repeat(2, minmax(0,1fr));
}
@media (min-width: 1024px) { .v2-ind-grid { grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.1rem; } }
.v2-ind-card {
  display: flex; flex-direction: column; gap: 0.3rem;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  padding: 1.5rem 1.4rem;
  text-decoration: none;
  transition: background 0.25s, border-color 0.25s, transform 0.25s;
}
.v2-ind-card svg { margin-bottom: 0.6rem; transition: stroke 0.25s; }
.v2-ind-card:hover {
  background: rgba(0,84,223,0.1);
  border-color: rgba(0,84,223,0.3);
  transform: translateY(-4px);
}
.v2-ind-card:hover .industry-icon { stroke: #F96B2B !important; }
.v2-ind-name { font: 700 1rem/1.25 'Inter Tight', sans-serif; color: #fff; }
.v2-ind-sub { font: 600 0.72rem/1.3 'Inter Tight', sans-serif; color: rgba(255,255,255,0.34); }
.v2-ind-note {
  margin: 2rem auto 0; text-align: center; max-width: 26rem;
  font: 500 0.88rem/1.6 'Inter Tight', sans-serif; color: rgba(255,255,255,0.35);
}

/* ---------- CTA ---------- */
.v2-cta {
  position: relative; overflow: hidden;
  background: #050e1c;
  padding-block: clamp(5rem, 9vw, 8.5rem);
}
.v2-cta-glow {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -55%);
  width: 62rem; height: 34rem; pointer-events: none;
  background:
    radial-gradient(ellipse at 32% 38%, rgba(249,107,43,0.14) 0%, transparent 55%),
    radial-gradient(ellipse at 70% 65%, rgba(45,125,255,0.13) 0%, transparent 55%);
}
.v2-cta-grid-bg {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 36px 36px;
}
.v2-cta-inner {
  position: relative; z-index: 2;
  max-width: 42rem; margin-inline: auto;
  padding-inline: 1.25rem; text-align: center;
}
.v2-cta-badge {
  display: inline-flex; align-items: center; gap: 0.6rem;
  border-radius: 999px;
  border: 1px solid rgba(249,107,43,0.22); background: rgba(249,107,43,0.09);
  padding: 0.6rem 1.2rem; margin-bottom: 2rem;
  font: 700 0.62rem/1 'Inter Tight', sans-serif;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(249,107,43,0.9);
}
.v2-cta-h2 {
  margin: 0 0 1.4rem;
  font-family: 'Oswald', sans-serif; font-weight: 700;
  font-size: clamp(3rem, 8.5vw, 6rem);
  line-height: 0.92; text-transform: uppercase; color: #fff;
}
.v2-cta-sub {
  margin: 0 auto 2.2rem; max-width: 30rem;
  font: 500 1.02rem/1.6 'Inter Tight', sans-serif;
  color: rgba(255,255,255,0.45);
}
.v2-form { display: flex; flex-direction: column; gap: 0.8rem; }
.v2-form-grid { display: grid; gap: 0.8rem; grid-template-columns: 1fr; }
@media (min-width: 640px) { .v2-form-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }
.v2-input {
  border-radius: 16px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 1.05rem 1.3rem;
  font: 500 0.9rem/1 'Inter Tight', sans-serif;
  color: #fff;
  transition: border-color 0.2s, background 0.2s;
}
.v2-input::placeholder { color: rgba(255,255,255,0.28); }
.v2-input:focus {
  outline: none;
  border-color: rgba(249,107,43,0.55);
  background: rgba(255,255,255,0.08);
}
.v2-submit {
  width: 100%;
  border: 0; border-radius: 16px;
  background: #F96B2B; color: #fff;
  padding: 1.3rem;
  font: 700 1rem/1 'Inter Tight', sans-serif;
  box-shadow: 0 16px 40px rgba(249,107,43,0.3);
  transition: opacity 0.2s, box-shadow 0.2s;
  will-change: transform;
}
.v2-submit:hover { opacity: 0.93; box-shadow: 0 22px 52px rgba(249,107,43,0.4); }
.v2-cta-fine {
  margin: 1.4rem 0 0;
  font: 500 0.75rem/1.5 'Inter Tight', sans-serif;
  color: rgba(255,255,255,0.24);
}

/* ---------- anchor offset under floating nav ---------- */
section[id] { scroll-margin-top: 5.75rem; }

/* ---------- mobile perf: cut GPU-heavy effects ---------- */
@media (max-width: 1023px) {
  .v2-aurora { animation: none !important; filter: blur(40px); }
  .v2-eyebrow, .v2-holiday, .v2-btn-ghost, .v2-panel-card { backdrop-filter: none; }
  .v2-mq-orange { box-shadow: none; }
  .ba-wrap { box-shadow: 0 24px 60px rgba(0,0,0,0.45); }
  .v2-btn-primary { box-shadow: 0 14px 30px rgba(249,107,43,0.32); }
  .v2-panel-blue, .v2-panel-orange, .v2-panel-green { box-shadow: 0 24px 50px rgba(0,0,0,0.4); }
  .v2-pricing::before, .v2-transform::before { filter: blur(36px); }
}

/* ---------- mobile polish ---------- */
@media (max-width: 767px) {
  .v2-hero { padding: 7.25rem 1.1rem 3.75rem; }
  .v2-holiday {
    max-width: 100%;
    text-align: center;
    justify-content: center;
    font-size: 0.62rem;
    padding: 0.42rem 0.85rem;
  }
  .v2-h1 { margin-top: 1.4rem; }
  .v2-rotator-row { margin-top: 1.3rem; }
  .v2-sub { margin-top: 1.1rem; font-size: 0.95rem; }
  .v2-ctas {
    margin-top: 1.7rem;
    width: 100%; max-width: 22rem;
    flex-direction: column; align-items: stretch;
  }
  .v2-btn-primary, .v2-btn-ghost { width: 100%; padding-inline: 1.4rem; }
  .v2-proof { margin-top: 2.1rem; }
  .v2-scroll-cue { display: none; }
  .v2-lede { font-size: 0.94rem; }
  .ba-footnote { font-size: 0.84rem; }
  .v2-big-price { -webkit-text-stroke-width: 1.5px; }
  .v2-price-chips { gap: 0.45rem; }
  .v2-chip { padding: 0.5rem 0.85rem; font-size: 0.6rem; }
}

/* very narrow phones */
@media (max-width: 379px) {
  .v2-h1 { font-size: 2.95rem; }
  .v2-cta-h2 { font-size: 2.6rem; }
  .v2-proof-n { font-size: 1.45rem; }
}

/* short viewports: keep hero breathable */
@media (max-height: 740px) and (min-width: 768px) {
  .v2-scroll-cue { display: none; }
  .v2-hero { padding-top: 7.5rem; padding-bottom: 4rem; }
}

/* ---------- reduced motion ---------- */
@media (prefers-reduced-motion: reduce) {
  .mq-left, .mq-right, .v2-aurora, .v2-cue-dot, .v2-pulse-dot::before,
  .v2-spark, .ba-old-blink, .v2-btn-ghost svg {
    animation: none !important;
  }
  #cur-dot, #cur-ring { display: none !important; }
}
