---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Midvora - Modern Websites for Local Business">

<!-- ===================== HERO ===================== -->
<section id="hero" class="h-new-hero relative overflow-hidden" style="background:#050e1c;">

  <!-- ░░ LAYER 0 — deep atmosphere ░░ -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <!-- Primary blue nebula, upper-left -->
    <div class="h-glow-blue"></div>
    <!-- Orange ember, lower-right -->
    <div class="h-glow-orange"></div>
    <!-- Secondary cold glow, upper-right -->
    <div class="h-glow-cold"></div>
    <!-- Fine dot-matrix grid, masked to center -->
    <div class="h-dotgrid"></div>
    <!-- Scanline texture overlay -->
    <div class="h-scanlines"></div>
    <!-- Diagonal orange slash accent — desktop only -->
    <div class="h-slash"></div>
  </div>

  <!-- ░░ LAYER 1 — canvas (desktop particle web) ░░ -->
  <canvas id="hero-canvas" class="h-canvas pointer-events-none absolute inset-0" style="opacity:0.35;"></canvas>

  <!-- ░░ LAYER 2 — content ░░ -->
  <div class="h-content relative z-10 mx-auto w-full max-w-7xl" style="padding:0 1.25rem;">

    <!-- ══ DESKTOP two-col ══ -->
    <div class="h-grid" style="min-height:100svh;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;padding:6rem 1rem 5rem;">

      <!-- Left copy -->
      <div class="h-copy">
        <div class="h-pill hero-eyebrow">
          <span class="h-dot-pulse"></span>
          <span>Midwest Web Design · MN / SD / ND</span>
        </div>

        <div class="holiday-ribbon hero-holiday" aria-label="July 4th weekend launch note">
          <div class="holiday-mark" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div>
            <p>July 4th weekend sprint</p>
            <span>Bright local sites for busy summer traffic.</span>
          </div>
        </div>

        <h1 class="h-headline hero-h1">
          <span class="h-line-1">Your business</span>
          <span class="h-line-2">deserves a site</span>
          <span class="h-line-3">that <em class="h-em">actually</em> works.</span>
        </h1>

        <p class="h-sub hero-sub">
          We build your full homepage sample in&nbsp;24&nbsp;hours, free, live, and real. You only pay when you love it.
        </p>

        <div class="h-ctas hero-ctas">
          <a href="/contact" class="h-btn-primary group">
            Get my free sample
            <svg class="h-btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#services-section" class="h-btn-ghost">See what we build</a>
        </div>

        <div class="h-stats hero-proof-strip">
          <div class="h-stat"><span class="h-stat-n">$0</span><span class="h-stat-l">Up front</span></div>
          <div class="h-stat-sep"></div>
          <div class="h-stat"><span class="h-stat-n">24h</span><span class="h-stat-l">Sample ready</span></div>
          <div class="h-stat-sep"></div>
          <div class="h-stat"><span class="h-stat-n">5–7</span><span class="h-stat-l">Days live</span></div>
        </div>
      </div>

      <!-- Right visual: stacked phone + floating cards -->
      <div class="h-visual hero-visual" style="position:relative;height:560px;">

        <!-- Glow ring behind phone -->
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(0,84,223,0.28) 0%,transparent 70%);filter:blur(32px);pointer-events:none;"></div>

        <!-- Phone frame -->
        <div class="h-phone hero-browser" style="position:absolute;top:50%;left:50%;transform:translate(-48%,-50%) rotate(-4deg);">
          <div class="h-phone-notch"></div>
          <div class="h-phone-screen">
            <!-- Mini site preview inside phone -->
            <div style="background:linear-gradient(150deg,#0054DF,#031e4a);padding:1rem;border-radius:4px 4px 0 0;">
              <p style="margin:0 0 0.3rem;font:700 0.56rem/1 'Inter Tight',sans-serif;color:rgba(255,255,255,0.55);letter-spacing:0.14em;text-transform:uppercase;">Your sample site</p>
              <p style="margin:0 0 0.5rem;font-family:'Oswald',sans-serif;font-size:1.3rem;font-weight:700;color:#fff;line-height:1;">Bella Salon &amp; Spa</p>
              <p style="margin:0 0 0.75rem;font:500 0.68rem/1.4 'Inter Tight',sans-serif;color:rgba(255,255,255,0.62);">Book same-day. Walk-ins welcome.</p>
              <div style="display:flex;gap:0.4rem;">
                <span style="background:#F96B2B;color:#fff;border-radius:999px;padding:0.4rem 0.75rem;font:700 0.58rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Book Now</span>
                <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.72);border-radius:999px;padding:0.4rem 0.75rem;font:700 0.58rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Services</span>
              </div>
            </div>
            <div style="padding:0.7rem;display:flex;flex-direction:column;gap:0.5rem;">
              {[
                {w:'72%',s:'0.85'},
                {w:'55%',s:'0.7'},
                {w:'88%',s:'0.6'},
              ].map(r => (
                <div style={`height:0.4rem;border-radius:999px;background:rgba(255,255,255,0.12);width:${r.w};opacity:${r.s};`}></div>
              ))}
              <div style="margin-top:0.25rem;display:flex;justify-content:flex-end;">
                <span style="background:#F96B2B;color:#fff;border-radius:999px;padding:0.42rem 0.8rem;font:700 0.58rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Tap to Call</span>
              </div>
            </div>
          </div>
          <div class="h-phone-home"></div>
        </div>

        <!-- Floating badge: 24h -->
        <div class="h-float-badge motion-safe-float" style="position:absolute;top:12%;left:4%;background:#F96B2B;border-radius:16px;padding:0.9rem 1.1rem;box-shadow:0 20px 48px rgba(249,107,43,0.4);">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.7rem;font-weight:700;color:#fff;line-height:1;">24h</p>
          <p style="margin:0.25rem 0 0;font:700 0.55rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.14em;color:rgba(255,255,255,0.8);">Delivery</p>
        </div>

        <!-- Floating badge: $0 -->
        <div class="h-float-badge motion-safe-float-alt" style="position:absolute;bottom:14%;right:3%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);backdrop-filter:blur(16px);border-radius:16px;padding:0.9rem 1.1rem;">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.7rem;font-weight:700;color:#fff;line-height:1;">$0</p>
          <p style="margin:0.25rem 0 0;font:700 0.55rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.14em;color:rgba(255,255,255,0.45);">To start</p>
        </div>

        <!-- Floating card: "Live in 5 days" -->
        <div class="h-float-card motion-safe-float" style="position:absolute;top:10%;right:2%;background:rgba(10,22,40,0.9);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(20px);border-radius:14px;padding:0.75rem 1rem;min-width:130px;">
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
            <div style="width:6px;height:6px;border-radius:50%;background:#28CA41;box-shadow:0 0 8px 2px rgba(40,202,65,0.6);flex-shrink:0;"></div>
            <span style="font:700 0.6rem/1 'Inter Tight',sans-serif;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.12em;">Status</span>
          </div>
          <p style="margin:0;font:700 0.85rem/1.2 'Inter Tight',sans-serif;color:#fff;">Live in 5 days</p>
        </div>

        <!-- Floating card: check marks -->
        <div class="h-float-card motion-safe-float-alt" style="position:absolute;bottom:18%;left:1%;background:rgba(10,22,40,0.9);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(20px);border-radius:14px;padding:0.75rem 1rem;min-width:148px;">
          {['Custom design','Mobile ready','SEO ready'].map(t => (
            <div style="display:flex;align-items:center;gap:0.45rem;margin-bottom:0.35rem;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#28CA41" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/></svg>
              <span style={`font:600 0.7rem/1 'Inter Tight',sans-serif;color:rgba(255,255,255,0.72);`}>{t}</span>
            </div>
          ))}
        </div>

      </div>
    </div>

    <!-- ══ MOBILE full-bleed layout ══ -->
    <div class="h-mobile" style="display:flex;flex-direction:column;padding:3.15rem 0 0;">

      <!-- Top: copy -->
      <div style="padding:0 0.25rem;flex:0 0 auto;">
        <div class="h-pill hero-eyebrow" style="margin-bottom:1.5rem;">
          <span class="h-dot-pulse"></span>
          <span>MN · SD · ND</span>
        </div>

        <div class="holiday-ribbon hero-holiday" aria-label="July 4th weekend launch note" style="margin:0 0 1.35rem;">
          <div class="holiday-mark" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div>
            <p>July 4th weekend sprint</p>
            <span>Bright local sites for summer traffic.</span>
          </div>
        </div>

        <h1 class="h-headline-mob hero-h1">
          Your<br/>
          business<br/>
          deserves<br/>
          <em class="h-em-mob">better.</em>
        </h1>

        <p class="h-sub-mob hero-sub" style="margin-top:1.25rem;">
          We build your full homepage sample in&nbsp;24&nbsp;hours, free. You only pay when you love it.
        </p>

        <div style="margin-top:1.75rem;display:flex;flex-direction:column;gap:0.75rem;" class="hero-ctas">
          <a href="/contact" class="h-btn-primary group">
            Get my free sample
            <svg class="h-btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#services-section" class="h-btn-ghost">See what we build</a>
        </div>
      </div>

      <!-- Middle: phone + flanking badges in a flex row -->
      <div class="h-phone-wrap" style="margin-top:2rem;display:flex;align-items:center;justify-content:center;gap:0.75rem;">

        <!-- Left badge: $0 -->
        <div class="motion-safe-float-alt" style="flex-shrink:0;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);backdrop-filter:blur(16px);border-radius:14px;padding:0.85rem 0.9rem;text-align:center;">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.45rem;font-weight:700;color:#fff;line-height:1;">$0</p>
          <p style="margin:0.2rem 0 0;font:700 0.5rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.4);">Up front</p>
        </div>

        <!-- Phone centred -->
        <div class="h-phone h-phone-mob" style="flex-shrink:0;position:relative;z-index:2;">
          <div class="h-phone-notch"></div>
          <div class="h-phone-screen">
            <div style="background:linear-gradient(150deg,#0054DF,#031e4a);padding:1rem 0.9rem;border-radius:4px 4px 0 0;">
              <p style="margin:0 0 0.25rem;font:700 0.54rem/1 'Inter Tight',sans-serif;color:rgba(255,255,255,0.5);letter-spacing:0.14em;text-transform:uppercase;">Your sample site</p>
              <p style="margin:0 0 0.45rem;font-family:'Oswald',sans-serif;font-size:1.25rem;font-weight:700;color:#fff;line-height:1;">Bella Salon &amp; Spa</p>
              <p style="margin:0 0 0.7rem;font:500 0.66rem/1.4 'Inter Tight',sans-serif;color:rgba(255,255,255,0.6);">Book same-day. Walk-ins welcome.</p>
              <div style="display:flex;gap:0.35rem;">
                <span style="background:#F96B2B;color:#fff;border-radius:999px;padding:0.38rem 0.7rem;font:700 0.56rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Book Now</span>
                <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.72);border-radius:999px;padding:0.38rem 0.7rem;font:700 0.56rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Services</span>
              </div>
            </div>
            <div style="padding:0.65rem 0.7rem;display:flex;flex-direction:column;gap:0.45rem;">
              {[{w:'70%'},{w:'52%'},{w:'84%'}].map(r => (
                <div style={`height:0.38rem;border-radius:999px;background:rgba(255,255,255,0.11);width:${r.w};`}></div>
              ))}
              <div style="margin-top:0.25rem;display:flex;justify-content:flex-end;">
                <span style="background:#F96B2B;color:#fff;border-radius:999px;padding:0.38rem 0.75rem;font:700 0.56rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.06em;">Tap to Call</span>
              </div>
            </div>
          </div>
          <div class="h-phone-home"></div>
        </div>

        <!-- Right badge: 24h -->
        <div class="motion-safe-float" style="flex-shrink:0;background:#F96B2B;border-radius:14px;padding:0.85rem 0.9rem;text-align:center;box-shadow:0 16px 36px rgba(249,107,43,0.42);">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.45rem;font-weight:700;color:#fff;line-height:1;">24h</p>
          <p style="margin:0.2rem 0 0;font:700 0.5rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.8);">Delivery</p>
        </div>

      </div>

      <!-- Bottom: stat strip pinned -->
      <div class="h-stats-mob hero-proof-strip" style="flex:0 0 auto;padding:1.5rem 0.25rem 2rem;display:flex;align-items:center;gap:0;border-top:1px solid rgba(255,255,255,0.06);margin-top:1.5rem;">
        <div style="flex:1;text-align:center;">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.75rem;font-weight:700;color:#fff;line-height:1;">$0</p>
          <p style="margin:0.3rem 0 0;font:700 0.55rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.14em;color:rgba(255,255,255,0.3);">Up front</p>
        </div>
        <div style="width:1px;height:2rem;background:rgba(255,255,255,0.1);flex-shrink:0;"></div>
        <div style="flex:1;text-align:center;">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.75rem;font-weight:700;color:#F96B2B;line-height:1;">24h</p>
          <p style="margin:0.3rem 0 0;font:700 0.55rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.14em;color:rgba(255,255,255,0.3);">Sample ready</p>
        </div>
        <div style="width:1px;height:2rem;background:rgba(255,255,255,0.1);flex-shrink:0;"></div>
        <div style="flex:1;text-align:center;">
          <p style="margin:0;font-family:'Oswald',sans-serif;font-size:1.75rem;font-weight:700;color:#fff;line-height:1;">5–7</p>
          <p style="margin:0.3rem 0 0;font:700 0.55rem/1 'Inter Tight',sans-serif;text-transform:uppercase;letter-spacing:0.14em;color:rgba(255,255,255,0.3);">Days live</p>
        </div>
      </div>

    </div><!-- end .h-mobile -->
  </div><!-- end .h-content -->

</section>

<style is:inline>
/* ── Layout switching: desktop vs mobile ── */
.h-grid   { display: none; }
.h-mobile { display: flex; }
.h-canvas { display: none; }
.h-slash  { display: none; }

@media (min-width: 1024px) {
  .h-grid   { display: grid; }
  .h-mobile { display: none !important; }
  .h-canvas { display: block; }
  .h-slash  { display: block; }
}

@supports not (min-height:100svh) {
  .h-grid { min-height:100vh !important; }
}

/* ── Atmosphere glows ── */
.h-glow-blue {
  position:absolute;
  top:-22%;left:-12%;
  width:72vw;height:72vw;
  max-width:58rem;max-height:58rem;
  background:radial-gradient(circle,rgba(0,84,223,0.28) 0%,transparent 60%);
  filter:blur(60px);
}
.h-glow-orange {
  position:absolute;
  bottom:-18%;right:-10%;
  width:56vw;height:56vw;
  max-width:50rem;max-height:50rem;
  background:radial-gradient(circle,rgba(249,107,43,0.22) 0%,transparent 60%);
  filter:blur(56px);
}
.h-glow-cold {
  position:absolute;
  top:8%;right:-6%;
  width:40vw;height:40vw;
  max-width:36rem;max-height:36rem;
  background:radial-gradient(circle,rgba(142,183,255,0.1) 0%,transparent 65%);
  filter:blur(48px);
}

/* ── Dot grid ── */
.h-dotgrid {
  position:absolute;inset:0;
  background-image:radial-gradient(rgba(255,255,255,0.06) 1px,transparent 1px);
  background-size:26px 26px;
  mask-image:radial-gradient(ellipse 85% 70% at 50% 38%,black 20%,transparent 100%);
}

/* ── Scanlines (very subtle) ── */
.h-scanlines {
  position:absolute;inset:0;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.06) 3px,rgba(0,0,0,0.06) 4px);
  pointer-events:none;
}

/* ── Diagonal slash accent ── */
.h-slash {
  position:absolute;
  top:-8%;right:3%;
  width:3px;
  height:130%;
  background:linear-gradient(180deg,transparent 0%,rgba(249,107,43,0.6) 30%,rgba(249,107,43,0.8) 55%,rgba(249,107,43,0.3) 80%,transparent 100%);
  transform:rotate(18deg);
  transform-origin:top center;
  filter:blur(1px);
}
.h-slash::before {
  content:'';
  position:absolute;
  top:0;left:-12px;
  width:28px;height:100%;
  background:linear-gradient(180deg,transparent 0%,rgba(249,107,43,0.12) 30%,rgba(249,107,43,0.18) 55%,rgba(249,107,43,0.06) 80%,transparent 100%);
  filter:blur(8px);
}

/* ── Eyebrow pill ── */
.h-pill {
  display:inline-flex;
  align-items:center;
  gap:0.6rem;
  border-radius:999px;
  border:1px solid rgba(255,255,255,0.12);
  background:rgba(255,255,255,0.05);
  padding:0.45rem 1rem;
  font:700 0.62rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.16em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.52);
  backdrop-filter:blur(8px);
}
.h-dot-pulse {
  display:inline-block;
  position:relative;
  width:6px;height:6px;
  border-radius:50%;
  background:#F96B2B;
  flex-shrink:0;
}
.h-dot-pulse::before {
  content:'';
  position:absolute;
  inset:-3px;
  border-radius:50%;
  background:rgba(249,107,43,0.5);
  animation:heroPing 1.8s ease-in-out infinite;
}
@keyframes heroPing {
  0%,100%{transform:scale(1);opacity:0.7;}
  60%{transform:scale(2.2);opacity:0;}
}

/* ── Desktop headline ── */
/* Holiday ribbon */
.holiday-ribbon {
  position:relative;
  display:flex;
  width:min(100%,31rem);
  align-items:center;
  gap:0.85rem;
  margin-top:1rem;
  overflow:hidden;
  border-radius:18px;
  border:1px solid rgba(255,255,255,0.16);
  background:
    linear-gradient(135deg,rgba(186,36,48,0.26),rgba(255,255,255,0.08) 48%,rgba(0,84,223,0.22)),
    rgba(255,255,255,0.05);
  padding:0.82rem 1rem;
  box-shadow:0 18px 46px rgba(0,0,0,0.2),inset 0 1px 0 rgba(255,255,255,0.16);
  backdrop-filter:blur(14px);
}
.holiday-ribbon::before {
  content:'';
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(115deg,transparent 0 14px,rgba(255,255,255,0.08) 14px 15px);
  opacity:0.45;
  pointer-events:none;
}
.holiday-ribbon::after {
  content:'';
  position:absolute;
  right:1rem;
  top:50%;
  width:4.5rem;
  height:4.5rem;
  border-radius:50%;
  background:
    linear-gradient(#fff,#fff) center/1px 100% no-repeat,
    linear-gradient(90deg,#fff,#fff) center/100% 1px no-repeat,
    linear-gradient(45deg,transparent 48%,rgba(255,255,255,0.82) 49% 51%,transparent 52%),
    linear-gradient(-45deg,transparent 48%,rgba(255,255,255,0.82) 49% 51%,transparent 52%);
  opacity:0.18;
  transform:translateY(-50%) rotate(12deg);
  pointer-events:none;
}
.holiday-mark {
  position:relative;
  z-index:1;
  display:grid;
  width:2.4rem;
  height:2.4rem;
  flex:0 0 auto;
  place-items:center;
  border-radius:999px;
  background:#fff;
  box-shadow:0 10px 24px rgba(0,0,0,0.22);
}
.holiday-mark span {
  position:absolute;
  width:1.55rem;
  height:0.18rem;
  border-radius:999px;
  background:#ba2430;
}
.holiday-mark span:nth-child(2) {
  transform:rotate(60deg);
  background:#0054DF;
}
.holiday-mark span:nth-child(3) {
  transform:rotate(-60deg);
  background:#F96B2B;
}
.holiday-ribbon div:last-child {
  position:relative;
  z-index:1;
  min-width:0;
}
.holiday-ribbon p {
  margin:0;
  font:700 0.72rem/1 'Inter Tight',sans-serif;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.88);
}
.holiday-ribbon div:last-child > span {
  display:block;
  margin-top:0.24rem;
  font:600 0.86rem/1.3 'Inter Tight',sans-serif;
  color:rgba(255,255,255,0.62);
