---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Midvora - Modern Websites for Local Business">

<!-- ═══════════════ GLOBAL FX LAYERS ═══════════════ -->
<div id="scroll-progress" aria-hidden="true"></div>
<div id="cur-dot" aria-hidden="true"></div>
<div id="cur-ring" aria-hidden="true"></div>

<!-- ═══════════════ HERO — WebGL particle morph ═══════════════ -->
<section id="hero" class="v2-hero">

  <!-- Layer 0: atmosphere -->
  <div class="v2-atmo" aria-hidden="true">
    <div class="v2-aurora v2-aurora-a"></div>
    <div class="v2-aurora v2-aurora-b"></div>
    <div class="v2-aurora v2-aurora-c"></div>
    <div class="v2-dotgrid"></div>
    <div class="v2-vignette"></div>
  </div>

  <!-- Layer 1: WebGL canvas (desktop) -->
  <canvas id="webgl-hero" aria-hidden="true"></canvas>

  <!-- Layer 2: content -->
  <div class="v2-hero-inner">

    <div class="v2-eyebrow hero-eyebrow">
      <span class="v2-pulse-dot"></span>
      <span>Midwest web studio &nbsp;·&nbsp; MN / SD / ND</span>
    </div>

    <div class="v2-holiday hero-eyebrow" aria-label="July 4th weekend note">
      <span class="v2-spark" aria-hidden="true"></span>
      <span>July 4th weekend sprint — bright local sites for summer traffic</span>
    </div>

    <h1 class="v2-h1">
      <span class="v2-h1-line" data-split>Your site.</span>
      <span class="v2-h1-line v2-h1-orange" data-split>Built free.</span>
      <span class="v2-h1-line" data-split>In 24 hours.</span>
    </h1>

    <div class="v2-rotator-row hero-sub">
      <span class="v2-rotator-label">Made for</span>
      <span class="v2-rotator" id="word-rotator"><span class="v2-word is-active">restaurants</span></span>
    </div>

    <p class="v2-sub hero-sub">
      We design and ship a real, working homepage for your business in 24 hours — free.
      You only pay when you love it. Live on the web in 5–7 days.
    </p>

    <div class="v2-ctas hero-ctas">
      <a href="/contact" class="v2-btn-primary" data-magnetic>
        <span class="v2-btn-fill" aria-hidden="true"></span>
        <span class="v2-btn-label">Get my free sample
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
      <a href="#transform" class="v2-btn-ghost" data-magnetic>Drag the difference
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </a>
    </div>

    <div class="v2-proof hero-proof-strip">
      <div class="v2-proof-item"><span class="v2-proof-n">$0</span><span class="v2-proof-l">Up front</span></div>
      <div class="v2-proof-sep"></div>
      <div class="v2-proof-item"><span class="v2-proof-n v2-orange">24h</span><span class="v2-proof-l">Sample ready</span></div>
      <div class="v2-proof-sep"></div>
      <div class="v2-proof-item"><span class="v2-proof-n">5–7</span><span class="v2-proof-l">Days live</span></div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="v2-scroll-cue hero-cue" aria-hidden="true">
    <div class="v2-cue-track"><div class="v2-cue-dot"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ═══════════════ DOUBLE MARQUEE ═══════════════ -->
<div class="v2-marquee-zone" aria-hidden="true">
  <div class="v2-mq v2-mq-orange">
    <div class="mq-track mq-left">
      <div class="mq-seg">
        <span>24-Hour Free Sample</span><i>✦</i>
        <span>No Payment Until You Love It</span><i>✦</i>
        <span>Live in 5–7 Days</span><i>✦</i>
        <span>Zero-Risk Guarantee</span><i>✦</i>
        <span>MN / SD / ND</span><i>✦</i>
        <span>Websites From $700</span><i>✦</i>
      </div>
      <div class="mq-seg">
        <span>24-Hour Free Sample</span><i>✦</i>
        <span>No Payment Until You Love It</span><i>✦</i>
        <span>Live in 5–7 Days</span><i>✦</i>
        <span>Zero-Risk Guarantee</span><i>✦</i>
        <span>MN / SD / ND</span><i>✦</i>
        <span>Websites From $700</span><i>✦</i>
      </div>
    </div>
  </div>
  <div class="v2-mq v2-mq-navy">
    <div class="mq-track mq-right">
      <div class="mq-seg">
        <span>Custom Design</span><i>✦</i>
        <span>Mobile First</span><i>✦</i>
        <span>Google Maps Ready</span><i>✦</i>
        <span>SEO Foundation</span><i>✦</i>
        <span>Month-To-Month Care</span><i>✦</i>
        <span>No Hidden Fees</span><i>✦</i>
      </div>
      <div class="mq-seg">
        <span>Custom Design</span><i>✦</i>
        <span>Mobile First</span><i>✦</i>
        <span>Google Maps Ready</span><i>✦</i>
        <span>SEO Foundation</span><i>✦</i>
        <span>Month-To-Month Care</span><i>✦</i>
        <span>No Hidden Fees</span><i>✦</i>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════ STATS ═══════════════ -->
<section id="stats-section" class="v2-stats">
  <div class="v2-shell">
    <div class="v2-stats-head" data-reveal>
      <p class="v2-kicker v2-kicker-blue">The instant proof</p>
      <h2 class="v2-h2 v2-ink">Numbers that make<br/><span class="v2-orange-grad">the offer real.</span></h2>
    </div>
    <div class="v2-stats-row">
      <div class="v2-stat" data-reveal style="--acc:#2D7DFF;">
        <p class="v2-stat-n"><span class="stat-counter" data-target="70" data-suffix="%">0%</span></p>
        <div class="v2-stat-bar"></div>
        <p class="v2-stat-t">Cheaper than agencies</p>
        <p class="v2-stat-d">Agencies charge $5k–$15k for the same build. We don't have a Manhattan office.</p>
      </div>
      <div class="v2-stat" data-reveal style="--acc:#F96B2B;">
        <p class="v2-stat-n"><span class="stat-counter" data-target="24" data-suffix="h">0h</span></p>
        <div class="v2-stat-bar"></div>
        <p class="v2-stat-t">Sample delivered</p>
        <p class="v2-stat-d">A real working homepage — not a mockup, not a wireframe, not a promise.</p>
      </div>
      <div class="v2-stat" data-reveal style="--acc:#16C784;">
        <p class="v2-stat-n">$0</p>
        <div class="v2-stat-bar"></div>
        <p class="v2-stat-t">Before approval</p>
        <p class="v2-stat-d">You review the finished sample first. Money only moves when you say yes.</p>
      </div>
      <div class="v2-stat" data-reveal style="--acc:#8B5CF6;">
        <p class="v2-stat-n">5–7<span class="v2-stat-unit">days</span></p>
        <div class="v2-stat-bar"></div>
        <p class="v2-stat-t">Approval to live</p>
        <p class="v2-stat-d">From "I love it" to fully live on your own domain in under a week.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ BEFORE / AFTER — drag slider ═══════════════ -->
<section id="transform" class="v2-transform">
  <div class="v2-shell">
    <div class="v2-transform-head" data-reveal>
      <p class="v2-kicker v2-kicker-orange">The glow-up</p>
      <h2 class="v2-h2 v2-white">Drag the line.<br/><span class="v2-dim">Watch 2009 disappear.</span></h2>
      <p class="v2-lede">This is the actual gap between the site you have and the site we hand you. Grab the handle and see for yourself.</p>
    </div>

    <div class="ba-wrap" id="ba" data-reveal style="--cut:50%;">

      <!-- AFTER (base layer, revealed on the right) -->
      <div class="ba-new" aria-hidden="true">
        <div class="ba-new-bar">
          <span class="ba-dot" style="background:#FF5F57;"></span>
          <span class="ba-dot" style="background:#FEBC2E;"></span>
          <span class="ba-dot" style="background:#28CA41;"></span>
          <span class="ba-url">bellasalon.com</span>
          <span class="ba-live"><i></i>Live</span>
        </div>
        <div class="ba-new-body">
          <div class="ba-new-hero">
            <p class="ba-new-eyebrow">Downtown Marshall · Walk-ins welcome</p>
            <p class="ba-new-title">Bella Salon<br/>&amp; Spa</p>
            <div class="ba-new-pills">
              <span class="ba-pill-solid">Book Now</span>
              <span class="ba-pill-ghost">Tap to Call</span>
            </div>
          </div>
          <div class="ba-new-row">
            <div class="ba-new-chip">★ 4.9 · 212 reviews</div>
            <div class="ba-new-chip">Open today until 7pm</div>
          </div>
          <div class="ba-new-lines">
            <div style="width:72%;"></div>
            <div style="width:54%;"></div>
            <div style="width:83%;"></div>
          </div>
        </div>
        <div class="ba-tag ba-tag-new">Your Midvora site</div>
      </div>

      <!-- BEFORE (top layer, clipped to the left of the handle) -->
      <div class="ba-old" aria-hidden="true">
        <div class="ba-old-bar">yourbusiness.angelfire.com/index2.htm</div>
        <div class="ba-old-body">
          <p class="ba-old-title">WELCOME TO OUR WEB SITE!!!</p>
          <p class="ba-old-nav"><u>Home</u> | <u>About Us</u> | <u>Photos</u> | <u>Guestbook</u> | <u>Links</u></p>
          <p class="ba-old-blink">★ NEW: We are now on the World Wide Web! ★</p>
          <div class="ba-old-table">
            <p>Hours: call for hours</p>
            <p>Located next to the gas station</p>
            <p><span class="ba-old-hl">CLICK HERE</span> for our menu (opens in Word)</p>
          </div>
          <div class="ba-old-construction">🚧 UNDER CONSTRUCTION 🚧</div>
          <p class="ba-old-counter">You are visitor No. 004,217</p>
          <p class="ba-old-fine">Best viewed in Internet Explorer 6 at 800x600</p>
        </div>
        <div class="ba-tag ba-tag-old">Your current site</div>
      </div>

      <!-- Divider + handle -->
      <div class="ba-line" aria-hidden="true"></div>
      <div class="ba-handle" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M9 18l-6-6 6-6M15 6l6 6-6 6"/></svg>
      </div>

      <input type="range" class="ba-range" id="ba-range" min="0" max="100" step="0.1" value="50" aria-label="Compare your current website with your Midvora website" />
    </div>

    <p class="ba-footnote" data-reveal>Every sample we send is a real, clickable page like the right side — built around <em>your</em> business, free, in 24 hours.</p>
  </div>
</section>

<!-- ═══════════════ HOW IT WORKS — pinned horizontal story ═══════════════ -->
<section id="how" class="v2-how">
  <div class="v2-how-header">
    <p class="v2-kicker v2-kicker-orange">The Midvora way</p>
    <h2 class="v2-h2 v2-white">We do the work first.<span class="v2-dim"> You decide after.</span></h2>
  </div>

  <div class="v2-how-viewport">
    <div class="v2-how-track" id="how-track">

      <article class="v2-panel">
        <span class="v2-panel-num" aria-hidden="true">01</span>
        <div class="v2-panel-card v2-panel-blue">
          <div class="v2-panel-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#8EB7FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3>We find you</h3>
          <p>We search Google Maps for great local businesses stuck with outdated or missing websites. No cold pitch decks — we come to you with the work already started.</p>
          <div class="v2-panel-foot"><span class="v2-panel-dot" style="background:#0054DF;box-shadow:0 0 10px 2px rgba(0,84,223,0.7);"></span>Step one · Research</div>
        </div>
      </article>

      <article class="v2-panel">
        <span class="v2-panel-num v2-num-orange" aria-hidden="true">02</span>
        <div class="v2-panel-card v2-panel-orange">
          <span class="v2-panel-flag">The magic step</span>
          <div class="v2-panel-icon v2-panel-icon-orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="#F96B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>We build it free</h3>
          <p>Within 24 hours you get a link to a real, working homepage for your business. Your name, your services, your town. Free either way — keep it even if you pass.</p>
          <div class="v2-panel-foot"><span class="v2-panel-dot" style="background:#F96B2B;box-shadow:0 0 10px 2px rgba(249,107,43,0.7);"></span>Step two · 24 hours</div>
        </div>
      </article>

      <article class="v2-panel">
        <span class="v2-panel-num" aria-hidden="true">03</span>
        <div class="v2-panel-card v2-panel-green">
          <div class="v2-panel-icon v2-panel-icon-green">
            <svg viewBox="0 0 24 24" fill="none" stroke="#28CA41" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="26" height="26"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <h3>You approve. We launch.</h3>
          <p>Love it? We polish, connect your domain, and go live in 5–7 days — starting at $700 with no hidden fees. Don't love it? You owe nothing. That's the whole deal.</p>
          <div class="v2-panel-foot"><span class="v2-panel-dot" style="background:#28CA41;box-shadow:0 0 10px 2px rgba(40,202,65,0.7);"></span>Step three · Live</div>
        </div>
      </article>

    </div>
  </div>
  <div class="v2-how-progress" aria-hidden="true"><div id="how-progress-fill"></div></div>
</section>

<!-- ═══════════════ WHAT YOU GET — 3D tilt cards ═══════════════ -->
<section id="deliverables" class="v2-deliver">
  <div class="v2-shell">
    <div class="v2-deliver-head" data-reveal>
      <p class="v2-kicker v2-kicker-blue">In the box</p>
      <h2 class="v2-h2 v2-ink">Everything a local site<br/><span class="v2-blue-grad">actually needs.</span></h2>
    </div>

    <div class="v2-tilt-grid">

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#2D7DFF;--acc-bg:rgba(45,125,255,0.1);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><circle cx="11" cy="11" r="2"/></svg>
        </div>
        <h3>Custom design</h3>
        <p>Designed from scratch around your business. No templates, no page builders, no "theme #47."</p>
      </div>

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#F96B2B;--acc-bg:rgba(249,107,43,0.1);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
        </div>
        <h3>Mobile-first build</h3>
        <p>Most of your customers find you on their phone. Your site is built for that screen first, not squeezed into it.</p>
      </div>

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#14B8A6;--acc-bg:rgba(20,184,166,0.12);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3>Google Business setup</h3>
        <p>Show up on Google Maps when neighbors search "near me." Profile, photos, hours — handled.</p>
      </div>

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#8B5CF6;--acc-bg:rgba(139,92,246,0.12);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </div>
        <h3>SEO foundation</h3>
        <p>Fast loads, clean structure, and the right local keywords baked in from day one — not bolted on later.</p>
      </div>

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#EC4899;--acc-bg:rgba(236,72,153,0.1);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3h-3zM20 14h1M14 20h1M20 20h1"/></svg>
        </div>
        <h3>Booking, menus &amp; QR</h3>
        <p>Tap-to-call, QR menus, booking links, order buttons — whatever your front counter needs to move faster.</p>
      </div>

      <div class="v2-tcard" data-tilt data-reveal>
        <span class="tilt-glare" aria-hidden="true"></span>
        <div class="v2-tcard-icon" style="--acc:#22C55E;--acc-bg:rgba(34,197,94,0.12);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h3>Care &amp; security</h3>
        <p>Month-to-month updates, backups, and security monitoring after launch. No contracts holding you hostage.</p>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════ PRICING BAND ═══════════════ -->
<section id="pricing" class="v2-pricing">
  <div class="v2-shell v2-pricing-grid">
    <div class="v2-pricing-copy" data-reveal>
      <p class="v2-kicker v2-kicker-orange">Simple pricing</p>
      <h2 class="v2-h2 v2-white">Websites starting<br/>at <span class="v2-orange-grad">$700.</span></h2>
      <p class="v2-lede">No hourly rates. No surprise invoices. No 14-page proposals. You see the finished sample, you see the price, you decide.</p>
      <div class="v2-price-chips">
        <span class="v2-chip" style="--dot:#16C784;">$0 up front</span>
        <span class="v2-chip" style="--dot:#F96B2B;">Free 24h sample</span>
        <span class="v2-chip" style="--dot:#22D3EE;">No hidden fees</span>
        <span class="v2-chip" style="--dot:#A78BFA;">Month-to-month care</span>
      </div>
      <a href="#cta-banner" class="v2-btn-primary v2-btn-mt" data-magnetic>
        <span class="v2-btn-fill" aria-hidden="true"></span>
        <span class="v2-btn-label">Start with the free sample
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
    <div class="v2-pricing-figure" data-reveal aria-hidden="true">
      <span class="v2-big-price">$700</span>
      <span class="v2-big-price-sub">is where it starts. $0 is where it begins.</span>
    </div>
  </div>
</section>

<!-- ═══════════════ INDUSTRIES — cursor spotlight ═══════════════ -->
<section id="industries" class="v2-industries">
  <div class="v2-spotlight" aria-hidden="true"></div>
  <div class="v2-shell">
    <div class="v2-ind-head" data-reveal>
      <p class="v2-kicker v2-kicker-blue">Who we serve</p>
      <h2 class="v2-h2 v2-white">Built for Main Street,<span class="v2-dim"> not Silicon Valley.</span></h2>
    </div>

    <div class="v2-ind-grid">
      <a href="/contact" class="v2-ind-card" data-reveal>
        <svg class="industry-icon" viewBox="0 0 24 24" fill="none" style="stroke:#4D9FFF;" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M3 11h18M5 11V7a7 7 0 0 1 14 0v4M2 11h20v2a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4v-2zM12 3v1"/></svg>
        <span class="v2-ind-name">Restaurants &amp; cafés</span>
        <span class="v2-ind-sub">Menus, hours, orders</span>
      </a>
      <a href="/contact" class="v2-ind-card" data-reveal>
        <svg class="industry-icon" viewBox="0 0 24 24" fill="none" style="stroke:#F472B6;" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.12 15.88M14.47 14.48 20 20M8.12 8.12 12 12"/></svg>
        <span class="v2-ind-name">Salons &amp; spas</span>
        <span class="v2-ind-sub">Booking, galleries</span>
      </a>
      <a href="/contact" class="v2-ind-card" data-reveal>
