---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Midvora - Modern Websites for Local Business">

<!-- ===================== HERO ===================== -->
<section id="hero" class="hero-section relative overflow-hidden" style="min-height:calc(100vh - 73px);background:#06101f;">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="hero-halo hero-halo-blue"></div>
    <div class="hero-halo hero-halo-orange"></div>
    <div class="hero-grid"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-[calc(100vh-73px)] max-w-7xl items-center px-4 sm:px-6 lg:px-8">
    <div class="hero-shell grid w-full gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:gap-12">
      <div class="hero-copy max-w-[35rem] py-14 sm:py-16 lg:py-24">
        <div class="hero-badge inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-4 py-2">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#F96B2B] opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[#F96B2B]"></span>
          </span>
          <span class="font-sans text-[0.68rem] font-bold uppercase tracking-[0.14em]" style="color:rgba(255,255,255,0.58);">Midwest web design - MN / SD / ND</span>
        </div>

        <h1 class="hero-headline mt-7 font-display font-bold leading-[0.92] tracking-tight text-white" style="font-size:clamp(2.95rem,7.4vw,6.15rem);">
          <span class="hero-line">We build the</span>
          <span class="hero-line">sample site first.</span>
          <span class="hero-line"><span class="hero-orange-line">You decide</span> after.</span>
        </h1>

        <p class="hero-sub mt-6 max-w-[32rem] font-sans text-[1rem] leading-relaxed sm:text-[1.06rem]" style="color:rgba(255,255,255,0.56);">
          Midvora builds a real homepage sample for restaurants, salons, contractors, and local shops in 24 hours so you can judge the work before you spend a dollar.
        </p>

        <div class="hero-ctas mt-9 flex flex-wrap gap-3.5">
          <a href="/contact" class="group inline-flex items-center gap-3 rounded-full bg-[#F96B2B] px-7 py-4 font-sans text-sm font-bold text-white shadow-[0_18px_36px_rgba(249,107,43,0.28)] transition-all hover:-translate-y-0.5 hover:opacity-95">
            Get My Free Sample
            <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
          <a href="/services" class="inline-flex items-center gap-3 rounded-full border border-white/10 px-7 py-4 font-sans text-sm font-bold transition-colors hover:border-white/20 hover:bg-white/5 hover:text-white" style="background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.76);">
            See Pricing
          </a>
        </div>

        <div class="hero-proof mt-9 grid grid-cols-3 gap-3 sm:gap-4">
          <div class="hero-proof-card">
            <p class="font-display text-[1.9rem] font-bold leading-none text-white">$0</p>
            <p class="mt-2 font-sans text-[0.68rem] font-bold uppercase tracking-[0.12em]" style="color:rgba(255,255,255,0.36);">Up front</p>
          </div>
          <div class="hero-proof-card">
            <p class="font-display text-[1.9rem] font-bold leading-none text-white">24h</p>
            <p class="mt-2 font-sans text-[0.68rem] font-bold uppercase tracking-[0.12em]" style="color:rgba(255,255,255,0.36);">Sample ready</p>
          </div>
          <div class="hero-proof-card">
            <p class="font-display text-[1.9rem] font-bold leading-none text-white">5-7</p>
            <p class="mt-2 font-sans text-[0.68rem] font-bold uppercase tracking-[0.12em]" style="color:rgba(255,255,255,0.36);">Days to launch</p>
          </div>
        </div>
      </div>

      <div class="hero-scene-shell flex items-center lg:justify-end">
        <div class="hero-scene perspective-stage">
          <div class="guide-plane hero-guide hero-guide-one"></div>
          <div class="guide-plane hero-guide hero-guide-two"></div>
          <div class="guide-plane hero-guide hero-guide-three"></div>

          <div class="perspective-card hero-scene-card hero-card-main">
            <div class="scene-window-bar">
              <div class="scene-dots">
                <span class="scene-dot" style="background:#FF5F57;"></span>
                <span class="scene-dot" style="background:#FFBD2E;"></span>
                <span class="scene-dot" style="background:#28CA41;"></span>
              </div>
              <div class="scene-address">sample.midvora.site</div>
            </div>
            <div class="scene-window-body">
              <div class="scene-hero-panel">
                <div class="scene-eyebrow">Sample homepage</div>
                <h3>North Prairie Dental</h3>
                <p>Family dentistry, urgent visits, and clean calls to action built to look good on phones first.</p>
                <div class="scene-pill-row">
                  <span class="scene-primary-pill">Request Appointment</span>
                  <span class="scene-secondary-pill">Insurance Info</span>
                </div>
              </div>
              <div class="scene-feature-grid">
                <div class="scene-surface">
                  <p class="scene-surface-label">Service block</p>
                  <div class="scene-line" style="width:72%;"></div>
                  <div class="scene-line scene-line-soft" style="width:54%;"></div>
                </div>
                <div class="scene-surface">
                  <p class="scene-surface-label">Trust content</p>
                  <div class="scene-line" style="width:64%;"></div>
                  <div class="scene-line scene-line-soft" style="width:46%;"></div>
                </div>
                <div class="scene-surface">
                  <p class="scene-surface-label">Call to action</p>
                  <div class="scene-primary-pill scene-primary-pill-compact">Tap to Call</div>
                </div>
              </div>
            </div>
          </div>

          <div class="perspective-card hero-scene-card hero-card-secondary motion-safe-float">
            <div class="scene-stack-card">
              <p class="scene-panel-label">Service flow</p>
              <div class="scene-list">
                <div class="scene-list-item">
                  <span>Hero CTA</span>
                  <span>01</span>
                </div>
                <div class="scene-list-item">
                  <span>Service cards</span>
                  <span>02</span>
                </div>
                <div class="scene-list-item">
                  <span>Map + hours</span>
                  <span>03</span>
                </div>
              </div>
            </div>
          </div>

          <div class="perspective-card hero-scene-card hero-card-mobile motion-safe-float-alt">
            <div class="scene-phone">
              <div class="scene-phone-notch"></div>
              <p class="scene-panel-label">Mobile preview</p>
              <div class="scene-phone-card">
                <div class="scene-line" style="width:68%;"></div>
                <div class="scene-line scene-line-soft" style="width:48%;"></div>
                <div class="scene-primary-pill scene-primary-pill-compact mt-3">Call Now</div>
              </div>
              <div class="scene-surface mt-3">
                <div class="scene-line" style="width:58%;"></div>
                <div class="scene-line scene-line-soft" style="width:74%;"></div>
              </div>
            </div>
          </div>

          <div class="perspective-card hero-scene-card hero-card-launch">
            <div class="scene-stack-card">
              <p class="scene-panel-label">Launch path</p>
              <div class="scene-step-list">
                <div class="scene-step-row">
                  <span class="scene-step-number">1</span>
                  <span>Review build</span>
                </div>
                <div class="scene-step-row">
                  <span class="scene-step-number">2</span>
                  <span>Request edits</span>
                </div>
                <div class="scene-step-row">
                  <span class="scene-step-number">3</span>
                  <span>Launch live</span>
                </div>
              </div>
            </div>
          </div>

          <div class="hero-scene-chip hero-chip-top motion-safe-float">
            <p class="font-display text-[1.65rem] font-bold leading-none text-white">24h</p>
            <p class="mt-1 font-sans text-[0.62rem] font-bold uppercase tracking-[0.14em]" style="color:rgba(255,255,255,0.76);">Sample delivery</p>
          </div>

          <div class="hero-scene-chip hero-chip-bottom motion-safe-float-alt">
            <p class="font-display text-[1.55rem] font-bold leading-none text-white">$0</p>
            <p class="mt-1 font-sans text-[0.62rem] font-bold uppercase tracking-[0.14em]" style="color:rgba(255,255,255,0.42);">Before approval</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-cue absolute bottom-7 left-1/2 hidden -translate-x-1/2 items-center gap-3 md:flex">
    <span class="font-sans text-[0.58rem] font-bold uppercase tracking-[0.22em]">Scroll</span>
    <div style="height:1px;width:42px;background:linear-gradient(to right,rgba(255,255,255,0.08),rgba(255,255,255,0.42),rgba(255,255,255,0.08));animation:scrollPulse 2s ease-in-out infinite;"></div>
  </div>
</section>

<!-- ===================== ORANGE MARQUEE ===================== -->
<div class="overflow-hidden select-none" style="background:#F96B2B;" aria-hidden="true">
  <div class="marquee-track flex gap-0 py-3 whitespace-nowrap" style="color:rgba(255,255,255,0.92);font-size:0.68rem;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;">
    {Array.from({length: 10}).map(() => (
      <>
        <span class="px-8">24-Hour Free Sample</span>
        <span style="opacity:0.45;padding:0 4px;">*</span>
        <span class="px-8">No Payment Until You Love It</span>
        <span style="opacity:0.45;padding:0 4px;">*</span>
        <span class="px-8">Live in 7-10 Days</span>
        <span style="opacity:0.45;padding:0 4px;">*</span>
        <span class="px-8">Zero-Risk Guarantee</span>
        <span style="opacity:0.45;padding:0 4px;">*</span>
        <span class="px-8">MN / SD / ND</span>
        <span style="opacity:0.45;padding:0 4px;">*</span>
      </>
    ))}
  </div>
</div>

<!-- ===================== BENTO STATS ===================== -->
<section id="stats-section" class="bg-[#F8F6F2] py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="bento-stat rounded-3xl p-8" style="background:#0A1628;grid-column:span 1;">
        <p style="color:rgba(255,255,255,0.35);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;">Cheaper than agencies</p>
        <p class="font-display font-bold leading-none" style="font-size:4rem;color:#F96B2B;">
          <span class="stat-counter" data-target="70" data-suffix="%">0%</span>
        </p>
        <p style="color:rgba(255,255,255,0.4);font-size:0.8rem;margin-top:10px;line-height:1.4;">Less than the market rate for the same quality</p>
      </div>

      <div class="bento-stat rounded-3xl p-8" style="background:#0054DF;">
        <p style="color:rgba(255,255,255,0.5);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;">Sample delivered in</p>
        <p class="font-display font-bold text-white leading-none" style="font-size:4rem;">
          <span class="stat-counter" data-target="24" data-suffix="h">0h</span>
        </p>
        <p style="color:rgba(255,255,255,0.5);font-size:0.8rem;margin-top:10px;line-height:1.4;">Real site, not a mockup</p>
      </div>

      <div class="bento-stat rounded-3xl p-8" style="background:#F96B2B;">
        <p style="color:rgba(255,255,255,0.6);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;">To get started</p>
        <p class="font-display font-bold text-white leading-none" style="font-size:4rem;">$0</p>
        <p style="color:rgba(255,255,255,0.65);font-size:0.8rem;margin-top:10px;line-height:1.4;">Pay only when you love it</p>
      </div>

      <div class="bento-stat rounded-3xl p-8" style="background:#111D35;">
        <p style="color:rgba(255,255,255,0.3);font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px;">Average launch time</p>
        <p class="font-display font-bold text-white leading-none" style="font-size:3rem;">5-7 <span style="font-size:1.3rem;font-family:'Inter Tight',sans-serif;font-weight:400;opacity:0.5;">days</span></p>
        <p style="color:rgba(255,255,255,0.35);font-size:0.8rem;margin-top:10px;line-height:1.4;">From approval to fully live</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section id="how-it-works" class="py-28 overflow-hidden" style="background:#06101f;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-20 text-center">
      <p style="color:#F96B2B;font-size:0.68rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:14px;">THE MIDVORA WAY</p>
      <h2 class="font-display font-bold text-white" style="font-size:clamp(2.4rem,5vw,4rem);line-height:1.05;">
        We do the work first.<br/><span style="color:rgba(255,255,255,0.3);">You decide after.</span>
      </h2>
    </div>

    <div id="steps-grid" class="grid grid-cols-1 gap-5 md:grid-cols-3">
      <div class="step-card relative overflow-hidden rounded-3xl p-10" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);transition:background 0.3s,border-color 0.3s,transform 0.3s;">
        <div class="font-display absolute top-6 right-7 select-none font-bold leading-none" style="font-size:7rem;color:rgba(255,255,255,0.03);">01</div>
        <div class="relative z-10">
          <div class="mb-7 flex h-14 w-14 items-center justify-center rounded-2xl" style="background:rgba(0,84,223,0.14);border:1px solid rgba(0,84,223,0.22);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3 class="mb-3 font-display text-2xl font-bold text-white">We Find You</h3>
          <p class="font-sans text-sm leading-relaxed" style="color:rgba(255,255,255,0.42);">We search Google Maps for businesses in your area with outdated or missing websites. No waiting required - we come to you.</p>
        </div>
      </div>

      <div class="step-card relative overflow-hidden rounded-3xl p-10" style="background:rgba(249,107,43,0.05);border:1px solid rgba(249,107,43,0.18);transition:background 0.3s,border-color 0.3s,transform 0.3s;">
        <div class="font-display absolute top-6 right-7 select-none font-bold leading-none" style="font-size:7rem;color:rgba(249,107,43,0.06);">02</div>
        <div class="relative z-10">
          <div class="mb-7 flex h-14 w-14 items-center justify-center rounded-2xl" style="background:rgba(249,107,43,0.12);border:1px solid rgba(249,107,43,0.25);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F96B2B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="mb-3 font-display text-2xl font-bold text-white">We Build It Free</h3>
          <p class="font-sans text-sm leading-relaxed" style="color:rgba(255,255,255,0.42);">Your real business name, photos, and info - we build a live working website in 24 hours. Not a mockup. An actual site with a real URL.</p>
        </div>
      </div>

      <div class="step-card relative overflow-hidden rounded-3xl p-10" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);transition:background 0.3s,border-color 0.3s,transform 0.3s;">
        <div class="font-display absolute top-6 right-7 select-none font-bold leading-none" style="font-size:7rem;color:rgba(255,255,255,0.03);">03</div>
        <div class="relative z-10">
          <div class="mb-7 flex h-14 w-14 items-center justify-center rounded-2xl" style="background:rgba(0,84,223,0.14);border:1px solid rgba(0,84,223,0.22);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0054DF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <h3 class="mb-3 font-display text-2xl font-bold text-white">You Decide</h3>
          <p class="font-sans text-sm leading-relaxed" style="color:rgba(255,255,255,0.42);">We send you the link. Love it? We launch it. Do not? Walk away free - we absorb the entire cost. No pressure, no pitch.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== HONEST PITCH (editorial split) ===================== -->
<section class="bg-[#F8F6F2] py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-start gap-16 lg:flex-row lg:gap-24">
      <div class="lg:basis-[44%] lg:sticky lg:top-24">
        <p style="color:#0054DF;font-size:0.68rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:16px;">The honest pitch</p>
        <h2 class="font-display font-bold leading-[0.92] text-[#0A1628]" style="font-size:clamp(2.8rem,5.5vw,5rem);">
          Built for<br/>businesses<br/>like <span class="text-[#F96B2B]">yours.</span>
        </h2>
        <a href="/contact" class="mt-10 inline-flex items-center gap-3 rounded-full px-8 py-4 text-sm font-bold text-white transition-all" style="background:#0A1628;">
          Get Started Free &rarr;
        </a>
      </div>

      <div class="pitch-list flex flex-col lg:basis-[56%]">
        <div class="pitch-item flex items-start gap-7 py-10" style="border-bottom:1px solid rgba(10,22,40,0.09);">
          <div class="font-display select-none font-bold leading-none" style="font-size:3.8rem;color:rgba(10,22,40,0.07);flex-shrink:0;width:64px;line-height:1;">01</div>
          <div>
            <h3 class="mb-2 font-display text-2xl font-bold text-[#0A1628]">We charge 70% less than agencies.</h3>
            <p class="font-sans text-sm leading-relaxed text-[#6B7280]">The average agency charges $5k-$15k for the same work. We do not have a Manhattan office or 40 account managers charging by the hour.</p>
          </div>
        </div>

        <div class="pitch-item flex items-start gap-7 py-10" style="border-bottom:1px solid rgba(10,22,40,0.09);">
          <div class="font-display select-none font-bold leading-none" style="font-size:3.8rem;color:rgba(249,107,43,0.12);flex-shrink:0;width:64px;line-height:1;">02</div>
          <div>
            <h3 class="mb-2 font-display text-2xl font-bold text-[#0A1628]">You see it before you pay a cent.</h3>
            <p class="font-sans text-sm leading-relaxed text-[#6B7280]">A real, live URL. Your business name on it. Your photos. Your hours. If you hate it, walk away - we absorb the cost entirely, no questions asked.</p>
          </div>
        </div>

        <div class="pitch-item flex items-start gap-7 py-10">
          <div class="font-display select-none font-bold leading-none" style="font-size:3.8rem;color:rgba(10,22,40,0.07);flex-shrink:0;width:64px;line-height:1;">03</div>
          <div>
            <h3 class="mb-2 font-display text-2xl font-bold text-[#0A1628]">That is the whole pitch.</h3>
            <p class="font-sans text-sm leading-relaxed text-[#6B7280]">No 90-minute sales calls. No discovery workshops. No retainers on day one. No contracts. Just a site that works and customers that find you.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== SAMPLE BREAKDOWN ===================== -->
<section id="sample-breakdown" class="section-space-tight relative overflow-hidden" style="background:#06101f;">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="hero-halo hero-halo-blue" style="top:-22%;left:-10%;width:36rem;height:28rem;opacity:0.72;"></div>
    <div class="hero-halo hero-halo-orange" style="bottom:-24%;right:-8%;width:30rem;height:24rem;opacity:0.52;"></div>
    <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:78px 78px;opacity:0.16;"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="sample-breakdown-copy mx-auto mb-14 max-w-3xl text-center lg:mx-0 lg:text-left">
      <p style="color:#F96B2B;font-size:0.68rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;margin-bottom:14px;">24-Hour Sample</p>
      <h2 class="font-display font-bold text-white leading-[1.0]" style="font-size:clamp(2.4rem,5vw,4.3rem);">
        What shows up in<br/><span style="color:rgba(255,255,255,0.42);">your free sample</span>
      </h2>
      <p class="mt-6 max-w-[40rem] font-sans text-sm leading-relaxed text-white/50 sm:text-base">
        Midvora proves the value by building first. You get a live working preview that shows the layout, mobile behavior, local search basics, and launch path before any money changes hands.
      </p>
    </div>

    <div id="sample-breakdown-grid" class="grid grid-cols-1 items-start gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10">
      <div class="sample-breakdown-preview perspective-stage">
        <div class="guide-plane sample-guide sample-guide-one"></div>
        <div class="guide-plane sample-guide sample-guide-two"></div>

        <div class="perspective-card sample-scene-layer sample-card-main">
          <div class="scene-window-bar">
            <div class="scene-dots">
              <span class="scene-dot" style="background:#FF5F57;"></span>
              <span class="scene-dot" style="background:#FFBD2E;"></span>
              <span class="scene-dot" style="background:#28CA41;"></span>
            </div>
            <div class="scene-address">yourbusiness.midvora.site</div>
          </div>
          <div class="scene-window-body">
            <div class="scene-hero-panel">
              <div class="scene-eyebrow">Sample preview</div>
              <h3>Marshall Home Services</h3>
              <p>Fast repairs, clean pricing, and a homepage that looks trustworthy before the first call.</p>
              <div class="scene-pill-row">
                <span class="scene-primary-pill">Book Estimate</span>
                <span class="scene-secondary-pill">View Services</span>
              </div>
            </div>
            <div class="scene-feature-grid">
              <div class="scene-surface">
                <p class="scene-surface-label">Service blocks</p>
                <div class="scene-line" style="width:75%;"></div>
