<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
(function () {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

  gsap.registerPlugin(ScrollTrigger);

  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var forceStaticPreview = new URLSearchParams(window.location.search).has('staticPreview');

  function setCounterFinalState() {
    document.querySelectorAll('.stat-counter').forEach(function (el) {
      var target = parseInt(el.dataset.target || '0', 10);
      el.textContent = target + (el.dataset.suffix || '');
    });
  }

  if (prefersReducedMotion || forceStaticPreview) {
    setCounterFinalState();
    return;
  }

  var heroTimeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

  heroTimeline
    .fromTo('.hero-badge', { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.55 })
    .fromTo('.hero-headline', { opacity: 0, y: 34 }, { opacity: 1, y: 0, duration: 0.85 }, '-=0.18')
    .fromTo('.hero-sub', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7 }, '-=0.45')
    .fromTo('.hero-ctas', { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.65 }, '-=0.38')
    .fromTo('.hero-proof-card', { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.55, stagger: 0.08 }, '-=0.26')
    .fromTo('.hero-guide', { opacity: 0, scale: 0.96 }, { opacity: 1, scale: 1, duration: 0.9, stagger: 0.08 }, '-=1.05')
    .fromTo('.hero-scene-card', { opacity: 0, y: 28, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 0.92, stagger: 0.12 }, '-=0.82')
    .fromTo('.hero-scene-chip', { opacity: 0, y: 18, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: 0.72, stagger: 0.08 }, '-=0.72');

  var statsAnimated = false;
  ScrollTrigger.create({
    trigger: '#stats-section',
    start: 'top 82%',
    once: true,
    onEnter: function () {
      if (statsAnimated) return;
      statsAnimated = true;

      gsap.fromTo(
        '.bento-stat',
        { opacity: 0, y: 36, scale: 0.97 },
        { opacity: 1, y: 0, scale: 1, duration: 0.75, ease: 'power2.out', stagger: 0.1 }
      );

      document.querySelectorAll('.stat-counter').forEach(function (el) {
        var obj = { val: 0 };
        gsap.to(obj, {
          val: parseInt(el.dataset.target || '0', 10),
          duration: 1.9,
          ease: 'power2.out',
          onUpdate: function () {
            el.textContent = Math.round(obj.val) + (el.dataset.suffix || '');
          }
        });
      });
    }
  });

  gsap.fromTo(
    '#steps-grid > div',
    { opacity: 0, y: 48 },
    {
      opacity: 1,
      y: 0,
      duration: 0.85,
      ease: 'power3.out',
      stagger: 0.15,
      scrollTrigger: { trigger: '#steps-grid', start: 'top 80%' }
    }
  );

  gsap.fromTo(
    '.pitch-item',
    { opacity: 0, x: -32 },
    {
      opacity: 1,
      x: 0,
      duration: 0.8,
      ease: 'power2.out',
      stagger: 0.18,
      scrollTrigger: { trigger: '.pitch-list', start: 'top 78%' }
    }
  );

  gsap.fromTo(
    '.sample-breakdown-copy > *',
    { opacity: 0, y: 20 },
    {
      opacity: 1,
      y: 0,
      duration: 0.72,
      ease: 'power2.out',
      stagger: 0.1,
      scrollTrigger: { trigger: '#sample-breakdown', start: 'top 76%' }
    }
  );

  gsap.fromTo(
    '.sample-guide',
    { opacity: 0, scale: 0.96 },
    {
      opacity: 1,
      scale: 1,
      duration: 0.9,
      ease: 'power2.out',
      stagger: 0.1,
      scrollTrigger: { trigger: '#sample-breakdown-grid', start: 'top 78%' }
    }
  );

  gsap.fromTo(
    '.sample-scene-layer',
    { opacity: 0, y: 28, scale: 0.97 },
    {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.12,
      scrollTrigger: { trigger: '#sample-breakdown-grid', start: 'top 78%' }
    }
  );

  gsap.fromTo(
    '.sample-scene-chip',
    { opacity: 0, y: 18, scale: 0.96 },
    {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.68,
      ease: 'power2.out',
      stagger: 0.08,
      scrollTrigger: { trigger: '#sample-breakdown-grid', start: 'top 74%' }
    }
  );

  gsap.fromTo(
    '.sample-breakdown-card',
    { opacity: 0, y: 24 },
    {
      opacity: 1,
      y: 0,
      duration: 0.72,
      ease: 'power2.out',
      stagger: 0.1,
      scrollTrigger: { trigger: '#sample-breakdown-grid', start: 'top 76%' }
    }
  );

  gsap.fromTo(
    '.sample-proof-chip',
    { opacity: 0, y: 20 },
    {
      opacity: 1,
      y: 0,
      duration: 0.55,
      ease: 'power2.out',
      stagger: 0.08,
      scrollTrigger: { trigger: '.sample-proof-row', start: 'top 88%' }
    }
  );

  gsap.fromTo(
    '#pricing-grid > div',
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out',
      stagger: 0.14,
      scrollTrigger: { trigger: '#pricing-grid', start: 'top 80%' }
    }
  );

  gsap.fromTo(
    '.trust-badge',
    { opacity: 0, y: 24 },
    {
      opacity: 1,
      y: 0,
      duration: 0.65,
      ease: 'power2.out',
      stagger: 0.1,
      scrollTrigger: { trigger: '.trust-badge', start: 'top 85%' }
    }
  );

  gsap.fromTo(
    '.cta-headline',
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power3.out',
      scrollTrigger: { trigger: '#cta-banner', start: 'top 80%' }
    }
  );

  gsap.fromTo(
    '#sample-form',
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out',
      delay: 0.2,
      scrollTrigger: { trigger: '#cta-banner', start: 'top 75%' }
    }
  );
})();

(function () {
  var form = document.getElementById('sample-form');
  if (!form) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = form.querySelector('button[type="submit"]');
    btn.textContent = 'Request received - we will be in touch soon.';
    btn.disabled = true;
    btn.style.background = '#22c55e';

    setTimeout(function () {
      btn.textContent = 'Build My Free Sample ->';
      btn.disabled = false;
      btn.style.background = '#F96B2B';
      form.reset();
    }, 4000);
  });
})();
</script>

