  <!-- interactive 3D tilt script -->
  <script is:inline>
  (function(){
    var cards = document.querySelectorAll('#how-it-works .step-card');
    cards.forEach(function(card, i) {
      var base = i === 1
        ? 'rotateY(0deg) rotateX(2deg) translateZ(40px) translateY(-16px)'
        : i === 0
          ? 'rotateY(12deg) rotateX(4deg) translateZ(0px)'
          : 'rotateY(-12deg) rotateX(4deg) translateZ(0px)';

      card.addEventListener('mouseenter', function() {
        if (window.innerWidth < 768) return;
        var tilt = i === 0 ? 'rotateY(6deg) rotateX(2deg) translateZ(20px)'
          : i === 1 ? 'rotateY(0deg) rotateX(0deg) translateZ(60px) translateY(-22px)'
          : 'rotateY(-6deg) rotateX(2deg) translateZ(20px)';
        card.style.transform = tilt;
        card.style.zIndex = '10';
      });

      card.addEventListener('mousemove', function(e) {
        if (window.innerWidth < 768) return;
        var rect = card.getBoundingClientRect();
        var cx = rect.left + rect.width / 2;
        var cy = rect.top + rect.height / 2;
        var dx = (e.clientX - cx) / rect.width;
        var dy = (e.clientY - cy) / rect.height;
        var baseX = i === 1 ? 0 : 4;
        var baseY = i === 0 ? 12 : i === 1 ? 0 : -12;
        var baseZ = i === 1 ? 40 : 0;
        var baseYt = i === 1 ? -16 : 0;
        card.style.transform =
          'rotateY(' + (baseY - dx * 6) + 'deg) ' +
          'rotateX(' + (baseX + dy * 4) + 'deg) ' +
          'translateZ(' + (baseZ + 24) + 'px) ' +
          'translateY(' + (baseYt - 8) + 'px)';
      });

      card.addEventListener('mouseleave', function() {
        if (window.innerWidth < 768) return;
        card.style.transform = base;
        card.style.zIndex = '';
      });
    });
  })();
  </script>
</section>

