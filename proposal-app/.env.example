# ─────────────────────────────────────────────────────────────────────────────
# Midvora Proposals — environment variables
# Copy this file to `.env.local` for local dev. NEVER commit real secrets.
# In production, set these in the Vercel project settings.
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL of this app (used to build the shareable proposal links).
# Local dev: http://localhost:3000   Production: https://sign.midvora.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Bypasses Row Level Security.
# Never expose this to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Resend ──────────────────────────────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Verified sender. Domain must be verified in Resend before this works.
# e.g. "Midvora <proposals@midvora.com>"
RESEND_FROM_EMAIL=Midvora <proposals@midvora.com>

# Internal copy recipient — every signed proposal is emailed here too.
INTERNAL_NOTIFY_EMAIL=info@Midvora.com
